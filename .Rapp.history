# EQL to SQL Query Engine#
# Optimized reimplementation using SQLite capabilities#
#
library(DBI)#
library(RSQLite)#
#
#' Parse EQL expression into an Abstract Syntax Tree#
#' @param eql_expr The EQL expression string#
#' @return A list representing the parsed AST#
parse_eql <- function(eql_expr) {#
  # Remove whitespace#
  expr <- gsub("\\s+", "", eql_expr)#
  # Tokenize the expression#
  tokens <- tokenize_eql(expr)#
  # Parse tokens into AST#
  parse_tokens(tokens)#
}#
#
#' Tokenize EQL expression#
tokenize_eql <- function(expr) {#
  # Define token patterns (order matters for longest match)#
  patterns <- list(#
    list(type = "ARROW", pattern = "->"),#
    list(type = "EQUALS", pattern = "==|="),#
    list(type = "NOT_EQUALS", pattern = "!="),#
    list(type = "REGEX_MATCH", pattern = "=~"),#
    list(type = "REGEX_NOT_MATCH", pattern = "!~"),#
    list(type = "GTE", pattern = ">="),#
    list(type = "LTE", pattern = "<="),#
    list(type = "GT", pattern = ">"),#
    list(type = "LT", pattern = "<"),#
    list(type = "HASH", pattern = "#"),#
    list(type = "PIPE", pattern = "\\|"),#
    list(type = "AND", pattern = "&"),#
    list(type = "CARET", pattern = "\\^"),#
    list(type = "COMMA", pattern = ","),#
    list(type = "LPAREN", pattern = "\\("),#
    list(type = "RPAREN", pattern = "\\)"),#
    list(type = "LBRACKET", pattern = "\\["),#
    list(type = "RBRACKET", pattern = "\\]"),#
    list(type = "QUOTE", pattern = "'"),#
    list(type = "FUNCTION", pattern = "Start|End|Medial|Num"),#
    list(type = "NUMBER", pattern = "\\d+"),#
    list(type = "IDENTIFIER", pattern = "[a-zA-Z_][a-zA-Z0-9_]*")#
  )#
  tokens <- list()#
  pos <- 1#
  while (pos <= nchar(expr)) {#
    matched <- FALSE#
    for (pattern in patterns) {#
      regex <- paste0("^", pattern$pattern)#
      match <- regexpr(regex, substr(expr, pos, nchar(expr)))#
      if (match > 0) {#
        match_length <- attr(match, "match.length")#
        token_value <- substr(expr, pos, pos + match_length - 1)#
        tokens <- append(tokens, list(list(#
          type = pattern$type,#
          value = token_value,#
          position = pos#
        )))#
        pos <- pos + match_length#
        matched <- TRUE#
        break#
      }#
    }#
    if (!matched) {#
      stop(paste("Unexpected character at position", pos, ":", substr(expr, pos, pos)))#
    }#
  }#
  tokens#
}#
#
#' Parse tokens into Abstract Syntax Tree#
parse_tokens <- function(tokens) {#
  parser <- list(tokens = tokens, pos = 1)#
  parse_expression(parser)#
}#
#
#' Parse main expression (handles precedence)#
parse_expression <- function(parser) {#
  parse_sequence(parser)#
}#
#
#' Parse sequence expressions (->)#
parse_sequence <- function(parser) {#
  left <- parse_dominance(parser)#
  while (parser$pos <= length(parser$tokens) && #
         parser$tokens[[parser$pos]]$type == "ARROW") {#
    parser$pos <- parser$pos + 1  # consume ->#
    right <- parse_dominance(parser)#
    left <- list(type = "sequence", left = left, right = right)#
  }#
  left#
}#
#
#' Parse dominance expressions (^)#
parse_dominance <- function(parser) {#
  left <- parse_conjunction(parser)#
  while (parser$pos <= length(parser$tokens) && #
         parser$tokens[[parser$pos]]$type == "CARET") {#
    parser$pos <- parser$pos + 1  # consume ^#
    right <- parse_conjunction(parser)#
    left <- list(type = "dominance", left = left, right = right)#
  }#
  left#
}#
#
#' Parse conjunction expressions (&)#
parse_conjunction <- function(parser) {#
  left <- parse_primary(parser)#
  while (parser$pos <= length(parser$tokens) && #
         parser$tokens[[parser$pos]]$type == "AND") {#
    parser$pos <- parser$pos + 1  # consume &#
    right <- parse_primary(parser)#
    left <- list(type = "conjunction", left = left, right = right)#
  }#
  left#
}#
#
#' Parse primary expressions (labels, functions, brackets)#
parse_primary <- function(parser) {#
  if (parser$pos > length(parser$tokens)) {#
    stop("Unexpected end of expression")#
  }#
  token <- parser$tokens[[parser$pos]]#
  # Handle brackets#
  if (token$type == "LBRACKET") {#
    parser$pos <- parser$pos + 1  # consume [#
    expr <- parse_expression(parser)#
    if (parser$pos > length(parser$tokens) || #
        parser$tokens[[parser$pos]]$type != "RBRACKET") {#
      stop("Expected closing bracket ]")#
    }#
    parser$pos <- parser$pos + 1  # consume ]#
    return(expr)#
  }#
  # Handle result modifier#
  result_modifier <- FALSE#
  if (token$type == "HASH") {#
    result_modifier <- TRUE#
    parser$pos <- parser$pos + 1#
    token <- parser$tokens[[parser$pos]]#
  }#
  # Handle functions#
  if (token$type == "FUNCTION") {#
    return(parse_function(parser, result_modifier))#
  }#
  # Handle label queries#
  if (token$type == "IDENTIFIER") {#
    return(parse_label_query(parser, result_modifier))#
  }#
  stop(paste("Unexpected token:", token$type, "at position", token$position))#
}#
#
#' Parse function calls (Start, End, Medial, Num)#
parse_function <- function(parser, result_modifier = FALSE) {#
  func_name <- parser$tokens[[parser$pos]]$value#
  parser$pos <- parser$pos + 1#
  if (parser$pos > length(parser$tokens) || #
      parser$tokens[[parser$pos]]$type != "LPAREN") {#
    stop("Expected ( after function name")#
  }#
  parser$pos <- parser$pos + 1  # consume (#
  # Parse parameters#
  params <- list()#
  while (parser$pos <= length(parser$tokens) && #
         parser$tokens[[parser$pos]]$type != "RPAREN") {#
    if (parser$tokens[[parser$pos]]$type == "IDENTIFIER") {#
      params <- append(params, parser$tokens[[parser$pos]]$value)#
      parser$pos <- parser$pos + 1#
    }#
    if (parser$pos <= length(parser$tokens) && #
        parser$tokens[[parser$pos]]$type == "COMMA") {#
      parser$pos <- parser$pos + 1  # consume ,#
    }#
  }#
  if (parser$pos > length(parser$tokens) || #
      parser$tokens[[parser$pos]]$type != "RPAREN") {#
    stop("Expected ) after function parameters")#
  }#
  parser$pos <- parser$pos + 1  # consume )#
  # Parse comparison operator and value for Num function#
  operator <- NULL#
  value <- NULL#
  if (func_name == "Num") {#
    if (parser$pos <= length(parser$tokens) && #
        parser$tokens[[parser$pos]]$type %in% c("EQUALS", "NOT_EQUALS", "GT", "LT", "GTE", "LTE")) {#
      operator <- parser$tokens[[parser$pos]]$value#
      parser$pos <- parser$pos + 1#
      if (parser$pos <= length(parser$tokens) && #
          parser$tokens[[parser$pos]]$type == "NUMBER") {#
        value <- as.integer(parser$tokens[[parser$pos]]$value)#
        parser$pos <- parser$pos + 1#
      }#
    }#
  } else {#
    # For position functions, expect = 0 or = 1#
    if (parser$pos <= length(parser$tokens) && #
        parser$tokens[[parser$pos]]$type == "EQUALS") {#
      operator <- parser$tokens[[parser$pos]]$value#
      parser$pos <- parser$pos + 1#
      if (parser$pos <= length(parser$tokens) && #
          parser$tokens[[parser$pos]]$type == "NUMBER") {#
        value <- as.integer(parser$tokens[[parser$pos]]$value)#
        parser$pos <- parser$pos + 1#
      }#
    }#
  }#
  list(#
    type = "function",#
    name = func_name,#
    params = params,#
    operator = operator,#
    value = value,#
    result_modifier = result_modifier#
  )#
}#
#
#' Parse label queries#
parse_label_query <- function(parser, result_modifier = FALSE) {#
  level <- parser$tokens[[parser$pos]]$value#
  parser$pos <- parser$pos + 1#
  # Parse operator#
  if (parser$pos > length(parser$tokens)) {#
    stop("Expected operator after level name")#
  }#
  operator <- parser$tokens[[parser$pos]]$value#
  parser$pos <- parser$pos + 1#
  # Parse label alternatives#
  labels <- list()#
  repeat {#
    if (parser$pos > length(parser$tokens)) {#
      stop("Expected label value")#
    }#
    # Handle quoted strings#
    if (parser$tokens[[parser$pos]]$type == "QUOTE") {#
      parser$pos <- parser$pos + 1  # consume opening quote#
      if (parser$pos > length(parser$tokens)) {#
        stop("Expected label value after quote")#
      }#
      label_value <- parser$tokens[[parser$pos]]$value#
      parser$pos <- parser$pos + 1#
      if (parser$pos > length(parser$tokens) || #
          parser$tokens[[parser$pos]]$type != "QUOTE") {#
        stop("Expected closing quote")#
      }#
      parser$pos <- parser$pos + 1  # consume closing quote#
    } else {#
      label_value <- parser$tokens[[parser$pos]]$value#
      parser$pos <- parser$pos + 1#
    }#
    labels <- append(labels, label_value)#
    # Check for pipe (alternative separator)#
    if (parser$pos <= length(parser$tokens) && #
        parser$tokens[[parser$pos]]$type == "PIPE") {#
      parser$pos <- parser$pos + 1  # consume |#
    } else {#
      break#
    }#
  }#
  list(#
    type = "label_query",#
    level = level,#
    operator = operator,#
    labels = labels,#
    result_modifier = result_modifier#
  )#
}#
#
#' Convert AST to SQL query#
#' @param ast The Abstract Syntax Tree from parse_eql()#
#' @param db_uuid Database UUID#
#' @param session Session name (optional)#
#' @param bundle Bundle name (optional)#
#' @return SQL query string#
ast_to_sql <- function(ast, db_uuid, session = NULL, bundle = NULL) {#
  # Build base conditions#
  base_conditions <- list(paste0("i.db_uuid = '", db_uuid, "'"))#
  if (!is.null(session)) {#
    base_conditions <- append(base_conditions, paste0("i.session = '", session, "'"))#
  }#
  if (!is.null(bundle)) {#
    base_conditions <- append(base_conditions, paste0("i.bundle = '", bundle, "'"))#
  }#
  # Convert AST to SQL#
  sql_parts <- ast_to_sql_recursive(ast, base_conditions)#
  # Build final query#
  select_clause <- build_select_clause(ast)#
  from_clause <- sql_parts$from#
  where_clause <- if (length(sql_parts$where) > 0) {#
    paste("WHERE", paste(sql_parts$where, collapse = " AND "))#
  } else {#
    ""#
  }#
  paste(select_clause, from_clause, where_clause)#
}#
#
#' Recursively convert AST nodes to SQL#
ast_to_sql_recursive <- function(node, base_conditions, alias_counter = list(value = 1)) {#
  switch(node$type,#
    "label_query" = label_query_to_sql(node, base_conditions, alias_counter),#
    "function" = function_to_sql(node, base_conditions, alias_counter),#
    "sequence" = sequence_to_sql(node, base_conditions, alias_counter),#
    "dominance" = dominance_to_sql(node, base_conditions, alias_counter),#
    "conjunction" = conjunction_to_sql(node, base_conditions, alias_counter),#
    stop(paste("Unknown node type:", node$type))#
  )#
}#
#
#' Convert label query to SQL#
label_query_to_sql <- function(node, base_conditions, alias_counter) {#
  alias <- paste0("i", alias_counter$value)#
  alias_counter$value <- alias_counter$value + 1#
  # Build label condition#
  label_conditions <- sapply(node$labels, function(label) {#
    switch(node$operator,#
      "=" = ,#
      "==" = paste0("l", alias, ".label = '", label, "'"),#
      "!=" = paste0("l", alias, ".label != '", label, "'"),#
      "=~" = paste0("l", alias, ".label REGEXP '", label, "'"),#
      "!~" = paste0("NOT l", alias, ".label REGEXP '", label, "'"),#
      stop(paste("Unsupported operator:", node$operator))#
    )#
  })#
  if (length(label_conditions) > 1) {#
    if (node$operator %in% c("!=", "!~")) {#
      label_condition <- paste(label_conditions, collapse = " AND ")#
    } else {#
      label_condition <- paste(label_conditions, collapse = " OR ")#
    }#
  } else {#
    label_condition <- label_conditions[1]#
  }#
  from_clause <- paste0(#
    "FROM items ", alias,#
    " JOIN labels l", alias, " ON ",#
    alias, ".db_uuid = l", alias, ".db_uuid AND ",#
    alias, ".session = l", alias, ".session AND ",#
    alias, ".bundle = l", alias, ".bundle AND ",#
    alias, ".item_id = l", alias, ".item_id"#
  )#
  where_conditions <- c(#
    paste(base_conditions, collapse = " AND "),#
    paste0(alias, ".level = '", node$level, "'"),#
    label_condition#
  )#
  list(#
    from = from_clause,#
    where = where_conditions,#
    result_alias = if (node$result_modifier) alias else NULL,#
    main_alias = alias#
  )#
}#
#
#' Convert function to SQL#
function_to_sql <- function(node, base_conditions, alias_counter) {#
  if (length(node$params) < 2) {#
    stop("Function requires at least 2 parameters")#
  }#
  level1 <- node$params[1]#
  level2 <- node$params[2]#
  alias1 <- paste0("i", alias_counter$value)#
  alias2 <- paste0("i", alias_counter$value + 1)#
  alias_counter$value <- alias_counter$value + 2#
  if (node$name %in% c("Start", "End", "Medial")) {#
    # Position functions#
    position_condition <- switch(node$name,#
      "Start" = paste0("NOT EXISTS (SELECT 1 FROM links l WHERE l.db_uuid = ", alias1, ".db_uuid AND l.session = ", alias1, ".session AND l.bundle = ", alias1, ".bundle AND l.to_id = ", alias1, ".item_id AND EXISTS (SELECT 1 FROM items pi WHERE pi.db_uuid = l.db_uuid AND pi.session = l.session AND pi.bundle = l.bundle AND pi.item_id = l.from_id AND pi.level = '", level2, "'))"),#
      "End" = paste0("NOT EXISTS (SELECT 1 FROM links l WHERE l.db_uuid = ", alias1, ".db_uuid AND l.session = ", alias1, ".session AND l.bundle = ", alias1, ".bundle AND l.from_id = ", alias1, ".item_id AND EXISTS (SELECT 1 FROM items ni WHERE ni.db_uuid = l.db_uuid AND ni.session = l.session AND ni.bundle = l.bundle AND ni.item_id = l.to_id AND ni.level = '", level2, "'))"),#
      "Medial" = paste0("EXISTS (SELECT 1 FROM links l1 WHERE l1.db_uuid = ", alias1, ".db_uuid AND l1.session = ", alias1, ".session AND l1.bundle = ", alias1, ".bundle AND l1.to_id = ", alias1, ".item_id AND EXISTS (SELECT 1 FROM items pi WHERE pi.db_uuid = l1.db_uuid AND pi.session = l1.session AND pi.bundle = l1.bundle AND pi.item_id = l1.from_id AND pi.level = '", level2, "')) AND EXISTS (SELECT 1 FROM links l2 WHERE l2.db_uuid = ", alias1, ".db_uuid AND l2.session = ", alias1, ".session AND l2.bundle = ", alias1, ".bundle AND l2.from_id = ", alias1, ".item_id AND EXISTS (SELECT 1 FROM items ni WHERE ni.db_uuid = l2.db_uuid AND ni.session = l2.session AND ni.bundle = l2.bundle AND ni.item_id = l2.to_id AND ni.level = '", level2, "'))")#
    )#
    # Add value condition if specified#
    if (!is.null(node$value)) {#
      if (node$value == 1) {#
        # Keep the position condition as is#
      } else {#
        # Negate the position condition#
        position_condition <- paste0("NOT (", position_condition, ")")#
      }#
    }#
    from_clause <- paste0("FROM items ", alias1)#
    where_conditions <- c(#
      base_conditions,#
      paste0(alias1, ".level = '", level1, "'"),#
      position_condition#
    )#
  } else if (node$name == "Num") {#
    # Count function#
    count_subquery <- paste0(#
      "(SELECT COUNT(*) FROM items ci ",#
      "JOIN links l ON ci.db_uuid = l.db_uuid AND ci.session = l.session AND ci.bundle = l.bundle AND ci.item_id = l.from_id ",#
      "WHERE l.db_uuid = ", alias2, ".db_uuid AND l.session = ", alias2, ".session AND l.bundle = ", alias2, ".bundle AND l.to_id = ", alias2, ".item_id ",#
      "AND ci.level = '", level1, "')"#
    )#
    count_condition <- switch(node$operator,#
      "=" = ,#
      "==" = paste0(count_subquery, " = ", node$value),#
      "!=" = paste0(count_subquery, " != ", node$value),#
      ">" = paste0(count_subquery, " > ", node$value),#
      "<" = paste0(count_subquery, " < ", node$value),#
      ">=" = paste0(count_subquery, " >= ", node$value),#
      "<=" = paste0(count_subquery, " <= ", node$value),#
      stop(paste("Unsupported operator for Num:", node$operator))#
    )#
    from_clause <- paste0("FROM items ", alias2)#
    where_conditions <- c(#
      base_conditions,#
      paste0(alias2, ".level = '", level2, "'"),#
      count_condition#
    )#
  }#
  list(#
    from = from_clause,#
    where = where_conditions,#
    result_alias = if (node$result_modifier) alias1 else NULL,#
    main_alias = alias1#
  )#
}#
#
#' Convert sequence to SQL#
sequence_to_sql <- function(node, base_conditions, alias_counter) {#
  left_sql <- ast_to_sql_recursive(node$left, base_conditions, alias_counter)#
  right_sql <- ast_to_sql_recursive(node$right, base_conditions, alias_counter)#
  # Create sequence condition using seq_idx#
  sequence_condition <- paste0(#
    left_sql$main_alias, ".seq_idx + 1 = ", right_sql$main_alias, ".seq_idx AND ",#
    left_sql$main_alias, ".level = ", right_sql$main_alias, ".level AND ",#
    left_sql$main_alias, ".db_uuid = ", right_sql$main_alias, ".db_uuid AND ",#
    left_sql$main_alias, ".session = ", right_sql$main_alias, ".session AND ",#
    left_sql$main_alias, ".bundle = ", right_sql$main_alias, ".bundle"#
  )#
  # Combine FROM clauses#
  from_clause <- paste(left_sql$from, ",", gsub("FROM ", "", right_sql$from))#
  # Combine WHERE conditions#
  where_conditions <- c(left_sql$where, right_sql$where, sequence_condition)#
  list(#
    from = from_clause,#
    where = where_conditions,#
    result_alias = coalesce(left_sql$result_alias, right_sql$result_alias),#
    main_alias = coalesce(left_sql$result_alias, right_sql$result_alias, left_sql$main_alias)#
  )#
}#
#
#' Convert dominance to SQL#
dominance_to_sql <- function(node, base_conditions, alias_counter) {#
  left_sql <- ast_to_sql_recursive(node$left, base_conditions, alias_counter)#
  right_sql <- ast_to_sql_recursive(node$right, base_conditions, alias_counter)#
  # Create dominance condition using links table#
  dominance_condition <- paste0(#
    "EXISTS (SELECT 1 FROM links l WHERE ",#
    "l.db_uuid = ", left_sql$main_alias, ".db_uuid AND ",#
    "l.session = ", left_sql$main_alias, ".session AND ",#
    "l.bundle = ", left_sql$main_alias, ".bundle AND ",#
    "l.from_id = ", left_sql$main_alias, ".item_id AND ",#
    "l.to_id = ", right_sql$main_alias, ".item_id)"#
  )#
  # Combine FROM clauses#
  from_clause <- paste(left_sql$from, ",", gsub("FROM ", "", right_sql$from))#
  # Combine WHERE conditions#
  where_conditions <- c(left_sql$where, right_sql$where, dominance_condition)#
  list(#
    from = from_clause,#
    where = where_conditions,#
    result_alias = coalesce(left_sql$result_alias, right_sql$result_alias),#
    main_alias = coalesce(left_sql$result_alias, right_sql$result_alias, left_sql$main_alias)#
  )#
}#
#
#' Convert conjunction to SQL#
conjunction_to_sql <- function(node, base_conditions, alias_counter) {#
  left_sql <- ast_to_sql_recursive(node$left, base_conditions, alias_counter)#
  right_sql <- ast_to_sql_recursive(node$right, base_conditions, alias_counter)#
  # For conjunction, items must be the same#
  conjunction_condition <- paste0(#
    left_sql$main_alias, ".db_uuid = ", right_sql$main_alias, ".db_uuid AND ",#
    left_sql$main_alias, ".session = ", right_sql$main_alias, ".session AND ",#
    left_sql$main_alias, ".bundle = ", right_sql$main_alias, ".bundle AND ",#
    left_sql$main_alias, ".item_id = ", right_sql$main_alias, ".item_id"#
  )#
  # Combine FROM clauses#
  from_clause <- paste(left_sql$from, ",", gsub("FROM ", "", right_sql$from))#
  # Combine WHERE conditions#
  where_conditions <- c(left_sql$where, right_sql$where, conjunction_condition)#
  list(#
    from = from_clause,#
    where = where_conditions,#
    result_alias = coalesce(left_sql$result_alias, right_sql$result_alias),#
    main_alias = coalesce(left_sql$result_alias, right_sql$result_alias, left_sql$main_alias)#
  )#
}#
#
#' Build SELECT clause based on result modifier#
build_select_clause <- function(ast) {#
  result_alias <- find_result_alias(ast)#
  if (!is.null(result_alias)) {#
    return(paste0("SELECT DISTINCT ", result_alias, ".*"))#
  } else {#
    # Default: return the first/main alias#
    main_alias <- find_main_alias(ast)#
    return(paste0("SELECT DISTINCT ", main_alias, ".*"))#
  }#
}#
#
#' Find result alias (marked with #) in AST#
find_result_alias <- function(node) {#
  if (is.list(node)) {#
    if (!is.null(node$result_modifier) && node$result_modifier) {#
      return("result_item")  # Will need to alias appropriately#
    }#
    for (child in node) {#
      if (is.list(child)) {#
        result <- find_result_alias(child)#
        if (!is.null(result)) return(result)#
      }#
    }#
  }#
  NULL#
}#
#
#' Find main alias in AST#
find_main_alias <- function(node) {#
  if (is.list(node) && !is.null(node$main_alias)) {#
    return(node$main_alias)#
  }#
  if (is.list(node)) {#
    for (child in node) {#
      if (is.list(child)) {#
        result <- find_main_alias(child)#
        if (!is.null(result)) return(result)#
      }#
    }#
  }#
  "i1"  # Default fallback#
}#
#
#' Utility function for null coalescing#
coalesce <- function(...) {#
  args <- list(...)#
  for (arg in args) {#
    if (!is.null(arg)) return(arg)#
  }#
  NULL#
}#
#
#' Main query function - reimplementation of emuR::query()#
#' @param emuDB emuDB object or database connection#
#' @param query EQL query string#
#' @param session Optional session filter#
#' @param bundle Optional bundle filter#
#' @param resultType Type of result to return ("segment", "event", etc.)#
#' @param timeRefSegmentLevel Reference level for timing#
#' @param calcTimes Whether to calculate start/end times#
#' @return Query results as data.frame#
newquery <- function(emuDB, query, session = NULL, bundle = NULL, #
                    resultType = "segment", timeRefSegmentLevel = NULL, #
                    calcTimes = TRUE) {#
  # Handle different input types#
  if (inherits(emuDB, "emuDBhandle")) {#
    # Extract database path and UUID from emuDB handle#
    db_path <- emuDB$basePath#
    db_uuid <- emuDB$uuid#
    # Connect to SQLite database#
    db_file <- file.path(db_path, paste0(db_uuid, ".sqlite"))#
    if (!file.exists(db_file)) {#
      stop("SQLite database file not found: ", db_file)#
    }#
    con <- dbConnect(RSQLite::SQLite(), db_file)#
    on.exit(dbDisconnect(con))#
  } else if (inherits(emuDB, "SQLiteConnection")) {#
    # Direct database connection#
    con <- emuDB#
    # Get database UUID from emu_db table#
    db_info <- dbGetQuery(con, "SELECT uuid FROM emu_db LIMIT 1")#
    if (nrow(db_info) == 0) {#
      stop("No database UUID found in emu_db table")#
    }#
    db_uuid <- db_info$uuid[1]#
  } else {#
    stop("emuDB must be either an emuDBhandle or SQLiteConnection")#
  }#
  # Parse EQL query#
  tryCatch({#
    ast <- parse_eql(query)#
  }, error = function(e) {#
    stop("Failed to parse EQL query: ", e$message)#
  })#
  # Convert AST to SQL#
  tryCatch({#
    sql_query <- ast_to_sql(ast, db_uuid, session, bundle)#
  }, error = function(e) {#
    stop("Failed to convert EQL to SQL: ", e$message)#
  })#
  # Execute SQL query#
  tryCatch({#
    results <- dbGetQuery(con, sql_query)#
  }, error = function(e) {#
    stop("Failed to execute SQL query: ", e$message, "\nSQL: ", sql_query)#
  })#
  # Post-process results if needed#
  if (calcTimes && nrow(results) > 0) {#
    # Calculate start and end times based on sample information#
    if ("sample_rate" %in% names(results) && #
        "sample_start" %in% names(results) && #
        "sample_dur" %in% names(results)) {#
      results$start <- results$sample_start / results$sample_rate#
      results$end <- (results$sample_start + results$sample_dur) / results$sample_rate#
    }#
  }#
  # Format results according to resultType#
  if (resultType == "segment") {#
    # Ensure required columns are present#
    required_cols <- c("db_uuid", "session", "bundle", "level", "start", "end")#
    missing_cols <- setdiff(required_cols, names(results))#
    if (length(missing_cols) > 0) {#
      warning("Missing columns in results: ", paste(missing_cols, collapse = ", "))#
    }#
  }#
  # Add labels to results#
  if (nrow(results) > 0) {#
    label_query <- "#
      SELECT l.db_uuid, l.session, l.bundle, l.item_id, l.name, l.label#
      FROM labels l#
      WHERE (l.db_uuid, l.session, l.bundle, l.item_id) IN (%s)#
    "#
    item_ids <- paste(sprintf("('%s','%s','%s',%d)", #
                             results$db_uuid, results$session, #
                             results$bundle, results$item_id), #
                     collapse = ",")#
    label_query <- sprintf(label_query, item_ids)#
    labels <- dbGetQuery(con, label_query)#
    # Merge labels with results#
    results <- merge(results, labels, #
                    by = c("db_uuid", "session", "bundle", "item_id"), #
                    all.x = TRUE)#
  }#
  return(results)#
}#
#
#' Performance optimized version using prepared statements and caching#
#' @param emuDB emuDB object or database connection#
#' @param query EQL query string#
#' @param session Optional session filter#
#' @param bundle Optional bundle filter#
#' @param resultType Type of result to return#
#' @param timeRefSegmentLevel Reference level for timing#
#' @param calcTimes Whether to calculate start/end times#
#' @param use_cache Whether to use query result caching#
#' @return Query results as data.frame#
newquery_optimized <- function(emuDB, query, session = NULL, bundle = NULL, #
                              resultType = "segment", timeRefSegmentLevel = NULL, #
                              calcTimes = TRUE, use_cache = TRUE) {#
  # Create cache key#
  cache_key <- digest::digest(list(query, session, bundle, resultType, calcTimes))#
  # Check cache if enabled#
  if (use_cache && exists(".eql_cache", envir = .GlobalEnv)) {#
    cache <- get(".eql_cache", envir = .GlobalEnv)#
    if (cache_key %in% names(cache)) {#
      return(cache[[cache_key]])#
    }#
  }#
  # Execute query#
  results <- newquery(emuDB, query, session, bundle, resultType, #
                     timeRefSegmentLevel, calcTimes)#
  # Store in cache#
  if (use_cache) {#
    if (!exists(".eql_cache", envir = .GlobalEnv)) {#
      assign(".eql_cache", list(), envir = .GlobalEnv)#
    }#
    cache <- get(".eql_cache", envir = .GlobalEnv)#
    cache[[cache_key]] <- results#
    assign(".eql_cache", cache, envir = .GlobalEnv)#
  }#
  return(results)#
}#
#
#' Clear the query cache#
clear_query_cache <- function() {#
  if (exists(".eql_cache", envir = .GlobalEnv)) {#
    rm(".eql_cache", envir = .GlobalEnv)#
  }#
}#
#
#' Batch query execution for multiple EQL queries#
#' @param emuDB emuDB object or database connection#
#' @param queries Vector of EQL query strings#
#' @param session Optional session filter#
#' @param bundle Optional bundle filter#
#' @return List of query results#
batch_query <- function(emuDB, queries, session = NULL, bundle = NULL) {#
  # Handle database connection#
  if (inherits(emuDB, "emuDBhandle")) {#
    # Use the existing connection from the emuDBhandle#
    con <- emuDB$connection#
    db_uuid <- emuDB$UUID#
    # Verify connection is still valid#
    if (!dbIsValid(con)) {#
      stop("Database connection is no longer valid")#
    }#
  } else if (inherits(emuDB, "SQLiteConnection")) {#
    con <- emuDB#
    db_info <- dbGetQuery(con, "SELECT uuid FROM emu_db LIMIT 1")#
    db_uuid <- db_info$uuid[1]#
  }#
  # Begin transaction for better performance#
  dbBegin(con)#
  on.exit(dbRollback(con), add = TRUE)#
  results <- list()#
  for (i in seq_along(queries)) {#
    tryCatch({#
      cat("Executing query", i, "of", length(queries), "\n")#
      results[[i]] <- newquery(con, queries[i], session, bundle)#
    }, error = function(e) {#
      warning("Query ", i, " failed: ", e$message)#
      results[[i]] <- data.frame()  # Empty result on error#
    })#
  }#
  dbCommit(con)#
  on.exit()  # Remove rollback handler#
  names(results) <- queries#
  return(results)#
}#
#
#' Create indexes to optimize query performance#
#' @param con Database connection#
create_performance_indexes <- function(con) {#
  indexes <- list(#
    # Composite indexes for common query patterns#
    "CREATE INDEX IF NOT EXISTS idx_items_composite ON items(db_uuid, session, bundle, level, seq_idx)",#
    "CREATE INDEX IF NOT EXISTS idx_labels_composite ON labels(db_uuid, session, bundle, item_id, name, label)",#
    "CREATE INDEX IF NOT EXISTS idx_links_composite ON links(db_uuid, session, bundle, from_id, to_id)",#
    # Indexes for timing queries#
    "CREATE INDEX IF NOT EXISTS idx_items_timing ON items(db_uuid, session, bundle, sample_start, sample_dur)",#
    # Indexes for hierarchical queries#
    "CREATE INDEX IF NOT EXISTS idx_links_hierarchy ON links(db_uuid, session, bundle, from_id)",#
    "CREATE INDEX IF NOT EXISTS idx_links_reverse ON links(db_uuid, session, bundle, to_id)",#
    # Level-specific indexes#
    "CREATE INDEX IF NOT EXISTS idx_items_level ON items(db_uuid, level)",#
    "CREATE INDEX IF NOT EXISTS idx_labels_level ON labels(db_uuid, bundle, session, item_id)"#
  )#
  for (index_sql in indexes) {#
    tryCatch({#
      dbExecute(con, index_sql)#
    }, error = function(e) {#
      warning("Failed to create index: ", e$message)#
    })#
  }#
  cat("Performance indexes created successfully\n")#
}#
#
#' Analyze query performance and suggest optimizations#
#' @param emuDB Database connection#
#' @param query EQL query string#
#' @return Query plan and performance suggestions#
analyze_query_performance <- function(emuDB, query) {#
  if (inherits(emuDB, "emuDBhandle")) {#
    db_path <- emuDB$basePath#
    db_uuid <- emuDB$uuid#
    db_file <- file.path(db_path, paste0(db_uuid, ".sqlite"))#
    con <- dbConnect(RSQLite::SQLite(), db_file)#
    on.exit(dbDisconnect(con))#
  } else {#
    con <- emuDB#
    db_info <- dbGetQuery(con, "SELECT uuid FROM emu_db LIMIT 1")#
    db_uuid <- db_info$uuid[1]#
  }#
  # Parse and convert query#
  ast <- parse_eql(query)#
  sql_query <- ast_to_sql(ast, db_uuid)#
  # Get query plan#
  plan_query <- paste("EXPLAIN QUERY PLAN", sql_query)#
  query_plan <- dbGetQuery(con, plan_query)#
  # Analyze the plan for potential issues#
  suggestions <- list()#
  if (any(grepl("SCAN", query_plan$detail, ignore.case = TRUE))) {#
    suggestions <- append(suggestions, "Consider adding indexes for scanned tables")#
  }#
  if (any(grepl("TEMP", query_plan$detail, ignore.case = TRUE))) {#
    suggestions <- append(suggestions, "Query uses temporary tables - consider query restructuring")#
  }#
  # Count the number of joins#
  join_count <- sum(grepl("items|labels|links", sql_query))#
  if (join_count > 5) {#
    suggestions <- append(suggestions, "Complex query with many joins - consider breaking into simpler queries")#
  }#
  list(#
    original_eql = query,#
    generated_sql = sql_query,#
    query_plan = query_plan,#
    suggestions = suggestions#
  )#
}#
#
#' Validate EQL syntax without executing#
#' @param query EQL query string#
#' @return List with validation results#
validate_eql_syntax <- function(query) {#
  tryCatch({#
    ast <- parse_eql(query)#
    list(#
      valid = TRUE,#
      ast = ast,#
      message = "Query syntax is valid"#
    )#
  }, error = function(e) {#
    list(#
      valid = FALSE,#
      ast = NULL,#
      message = e$message#
    )#
  })#
}#
#
#' Export query results to various formats#
#' @param results Query results data.frame#
#' @param filename Output filename#
#' @param format Output format ("csv", "json", "rds")#
export_results <- function(results, filename, format = "csv") {#
  switch(format,#
    "csv" = {#
      write.csv(results, filename, row.names = FALSE)#
    },#
    "json" = {#
      jsonlite::write_json(results, filename, pretty = TRUE)#
    },#
    "rds" = {#
      saveRDS(results, filename)#
    },#
    stop("Unsupported format: ", format)#
  )#
  cat("Results exported to:", filename, "\n")#
}#
#
# Example usage and testing functions#
#
#' Test the new query engine with example queries#
test_newquery <- function(emuDB) {#
  test_queries <- c(#
    # Simple label queries#
    "Phonetic == 'n'",#
    "Word != 'the'",#
    "Phoneme =~ '^[aeiou]'",#
    # Sequence queries#
    "[Phonetic == 't' -> Phonetic == 'u:']",#
    # Dominance queries  #
    "[Word == 'beautiful' ^ Phonetic == 'bj']",#
    # Function queries#
    "Start(Phonetic, Word) == 1",#
    "Num(Phonetic, Word) > 3",#
    # Complex combinations#
    "[Word == 'water' ^ [Phonetic == 'w' -> Phonetic == 'O:']]",#
    "#[Phonetic == 'n' & Word == 'and']"#
  )#
  cat("Testing", length(test_queries), "example queries...\n")#
  results <- list()#
  for (i in seq_along(test_queries)) {#
    cat("Testing query", i, ":", test_queries[i], "\n")#
    tryCatch({#
      start_time <- Sys.time()#
      result <- newquery(emuDB, test_queries[i])#
      end_time <- Sys.time()#
      results[[i]] <- list(#
        query = test_queries[i],#
        success = TRUE,#
        rows = nrow(result),#
        execution_time = as.numeric(end_time - start_time),#
        result = head(result, 3)  # Store first 3 rows for inspection#
      )#
      cat("  Success:", nrow(result), "rows in", #
          round(as.numeric(end_time - start_time), 3), "seconds\n")#
    }, error = function(e) {#
      results[[i]] <- list(#
        query = test_queries[i],#
        success = FALSE,#
        error = e$message#
      )#
      cat("  Error:", e$message, "\n")#
    })#
  }#
  return(results)#
}
newquery(ae,"Word=~.*")
library(jsonlite)#
library(xml2)#
library(dplyr)#
library(purrr)#
#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL) {#
  # If no output file specified, create one with .eaf extension#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read the JSON file#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  # Extract media file if not provided#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create XML document#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z"),#
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  # Add MEDIA_DESCRIPTOR if media file exists#
  if (!is.null(media_file)) {#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = paste0("file://", normalizePath(media_file, mustWork = FALSE)),#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  # Collect all time points and create time slots#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  # Process levels and collect time information#
  levels_data <- emu_data$levels#
  # First pass: collect all unique time points from SEGMENT and EVENT items#
  all_time_points <- c()#
  for (level in levels_data) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          # Convert samples to milliseconds (assuming sampleRate in Hz)#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          # EVENT items have samplePoint#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  # Sort and get unique time points#
  unique_times <- sort(unique(all_time_points))#
  # Create time slots for each unique time point#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Create linguistic types and constraints#
  # Add standard constraints first#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Track tier dependencies and annotation IDs#
  tier_hierarchy <- list()#
  annotation_id_map <- list()#
  # Create tiers and annotations#
  for (level in levels_data) {#
    # Determine linguistic type#
    if (level$type == "ITEM") {#
      ling_type_id <- paste0(level$name, "_type")#
      xml_add_child(doc, "LINGUISTIC_TYPE",#
                    LINGUISTIC_TYPE_ID = ling_type_id,#
                    TIME_ALIGNABLE = "false",#
                    CONSTRAINTS = "Symbolic_Association")#
    } else {#
      ling_type_id <- paste0(level$name, "_type")#
      xml_add_child(doc, "LINGUISTIC_TYPE",#
                    LINGUISTIC_TYPE_ID = ling_type_id,#
                    TIME_ALIGNABLE = "true")#
    }#
    # Create tier#
    tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = ling_type_id)#
    # Process items in this level#
    for (item in level$items) {#
      annotation <- xml_add_child(tier, "ANNOTATION")#
      # Get annotation value (first label value if exists)#
      annot_value <- ""#
      if (!is.null(item$labels) && length(item$labels) > 0) {#
        annot_value <- item$labels[[1]]$value#
      }#
      # Create appropriate annotation type#
      if (level$type == "SEGMENT") {#
        start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
        end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
        alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = paste0("a", item$id),#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
      } else if (level$type == "EVENT") {#
        point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
        # For EVENT, we create a zero-duration segment#
        alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = paste0("a", item$id),#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(point_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(point_ms)]])#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
      } else if (level$type == "ITEM") {#
        # ITEM types need to be linked as REF_ANNOTATION#
        # We'll handle these after processing links#
        annotation_id_map[[as.character(item$id)]] <- list(#
          tier = level$name,#
          annotation = annotation,#
          value = annot_value,#
          item = item#
        )#
      }#
      # Store annotation ID for later linking#
      if (level$type != "ITEM") {#
        annotation_id_map[[as.character(item$id)]] <- paste0("a", item$id)#
      }#
    }#
  }#
  # Process links to establish REF_ANNOTATIONs for ITEM levels#
  if (!is.null(emu_data$links)) {#
    # Build parent-child relationships#
    parent_map <- list()#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      if (!is.null(parent_map[[to_id]])) {#
        parent_map[[to_id]] <- c(parent_map[[to_id]], from_id)#
      } else {#
        parent_map[[to_id]] <- from_id#
      }#
    }#
    # Now create REF_ANNOTATIONs for ITEM annotations#
    for (item_id in names(annotation_id_map)) {#
      item_info <- annotation_id_map[[item_id]]#
      if (is.list(item_info) && !is.null(item_info$annotation)) {#
        # This is an ITEM annotation#
        parent_ids <- parent_map[[item_id]]#
        if (!is.null(parent_ids) && length(parent_ids) > 0) {#
          # Use the first parent (ELAN typically uses single parent)#
          parent_annot_id <- annotation_id_map[[as.character(parent_ids[1])]]#
          if (!is.null(parent_annot_id) && is.character(parent_annot_id)) {#
            # Remove the empty annotation and recreate with REF_ANNOTATION#
            xml_remove(item_info$annotation)#
            # Find the tier and recreate annotation#
            tier_node <- xml_find_first(doc, paste0("//TIER[@TIER_ID='", item_info$tier, "']"))#
            new_annotation <- xml_add_child(tier_node, "ANNOTATION")#
            ref_annot <- xml_add_child(new_annotation, "REF_ANNOTATION",#
                                       ANNOTATION_ID = paste0("a", item_id),#
                                       ANNOTATION_REF = parent_annot_id)#
            xml_add_child(ref_annot, "ANNOTATION_VALUE", item_info$value)#
          }#
        }#
      }#
    }#
  }#
  # Write the XML to file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}#
#
# Example usage:#
# convert_emu_to_eaf("msajc012_annot.json", "msajc012.eaf")
library(xmlwriter)
convert_emu_to_eaf("msajc012_annot.json", "msajc012_2.eaf")
convert_emu_to_eaf("msajc012_annot.json", "msajc012.eaf")
convert_emu_to_eaf("Documents/msajc012_annot.json", "msajc012.eaf")
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf")
library(jsonlite)#
library(xml2)#
library(dplyr)#
library(purrr)#
#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL) {#
  # If no output file specified, create one with .eaf extension#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read the JSON file#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  # Extract media file if not provided#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create XML document#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z"),#
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  # Add MEDIA_DESCRIPTOR if media file exists#
  if (!is.null(media_file)) {#
    media_url <- if (grepl("^/", media_file) || grepl("^[A-Za-z]:", media_file)) {#
      paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    } else {#
      paste0("file://", file.path(getwd(), media_file))#
    }#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Build hierarchy map from links#
  parent_child_map <- list()  # child_id -> parent_id#
  children_map <- list()      # parent_id -> list of child_ids#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      # Store parent-child relationship#
      parent_child_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Build level hierarchy - determine which levels depend on which#
  level_hierarchy <- list()#
  level_items <- list()#
  for (level in emu_data$levels) {#
    level_items[[level$name]] <- sapply(level$items, function(x) as.character(x$id))#
    # Check if any items in this level have parents in other levels#
    parent_levels <- c()#
    for (item in level$items) {#
      parent_id <- parent_child_map[[as.character(item$id)]]#
      if (!is.null(parent_id)) {#
        # Find which level the parent belongs to#
        for (other_level in emu_data$levels) {#
          if (any(sapply(other_level$items, function(x) as.character(x$id) == parent_id))) {#
            if (!(other_level$name %in% parent_levels)) {#
              parent_levels <- c(parent_levels, other_level$name)#
            }#
            break#
          }#
        }#
      }#
    }#
    if (length(parent_levels) > 0) {#
      # Use the first parent level found#
      level_hierarchy[[level$name]] <- parent_levels[1]#
    }#
  }#
  # Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  # Collect all time points from SEGMENT and EVENT items#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  # Create time slots for unique time points#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Add standard constraints#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Create linguistic types#
  for (level in emu_data$levels) {#
    if (level$type == "ITEM") {#
      # ITEM types should be non-time-alignable with appropriate constraint#
      constraint <- if (!is.null(level_hierarchy[[level$name]])) {#
        "Symbolic_Subdivision"#
      } else {#
        "Symbolic_Association"#
      }#
      xml_add_child(doc, "LINGUISTIC_TYPE",#
                    LINGUISTIC_TYPE_ID = paste0(level$name, "_type"),#
                    TIME_ALIGNABLE = "false",#
                    CONSTRAINTS = constraint)#
    } else {#
      xml_add_child(doc, "LINGUISTIC_TYPE",#
                    LINGUISTIC_TYPE_ID = paste0(level$name, "_type"),#
                    TIME_ALIGNABLE = "true")#
    }#
  }#
  # Track created annotations#
  annotation_map <- list()#
  # Create tiers - first pass for time-aligned annotations#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      tier_attrs <- list(#
        TIER_ID = level$name,#
        LINGUISTIC_TYPE_REF = paste0(level$name, "_type")#
      )#
      # Add parent reference if exists#
      if (!is.null(level_hierarchy[[level$name]])) {#
        tier_attrs$PARENT_REF <- level_hierarchy[[level$name]]#
      }#
      tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
      # Add annotations#
      for (item in level$items) {#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        # Get annotation value#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          # Combine multiple label values if they exist#
          label_values <- sapply(item$labels, function(l) l$value)#
          annot_value <- paste(label_values, collapse = "; ")#
        }#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = paste0("a", item$id),#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
          xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          # Events typically have the same start and end time#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = paste0("a", item$id),#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(point_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(point_ms)]])#
          xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        }#
        annotation_map[[as.character(item$id)]] <- paste0("a", item$id)#
      }#
    }#
  }#
  # Second pass - create ITEM tiers with REF_ANNOTATIONs#
  for (level in emu_data$levels) {#
    if (level$type == "ITEM") {#
      tier_attrs <- list(#
        TIER_ID = level$name,#
        LINGUISTIC_TYPE_REF = paste0(level$name, "_type")#
      )#
      # Add parent tier reference if exists#
      if (!is.null(level_hierarchy[[level$name]])) {#
        tier_attrs$PARENT_REF <- level_hierarchy[[level$name]]#
      }#
      tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
      # Group items by parent for proper sequencing#
      items_by_parent <- list()#
      for (item in level$items) {#
        item_id <- as.character(item$id)#
        parent_id <- parent_child_map[[item_id]]#
        if (is.null(parent_id)) {#
          parent_id <- "NO_PARENT"#
        }#
        if (is.null(items_by_parent[[parent_id]])) {#
          items_by_parent[[parent_id]] <- list()#
        }#
        items_by_parent[[parent_id]] <- append(items_by_parent[[parent_id]], list(item))#
      }#
      # Create REF_ANNOTATIONs#
      for (parent_id in names(items_by_parent)) {#
        items <- items_by_parent[[parent_id]]#
        previous_annot_id <- NULL#
        for (i in seq_along(items)) {#
          item <- items[[i]]#
          item_id <- as.character(item$id)#
          annotation <- xml_add_child(tier, "ANNOTATION")#
          # Get annotation value#
          annot_value <- ""#
          if (!is.null(item$labels) && length(item$labels) > 0) {#
            label_values <- sapply(item$labels, function(l) l$value)#
            annot_value <- paste(label_values, collapse = "; ")#
          }#
          # Create REF_ANNOTATION#
          ref_attrs <- list(#
            ANNOTATION_ID = paste0("a", item_id)#
          )#
          # Add parent reference if exists#
          if (parent_id != "NO_PARENT" && !is.null(annotation_map[[parent_id]])) {#
            ref_attrs$ANNOTATION_REF <- annotation_map[[parent_id]]#
          }#
          # Add previous annotation reference for chaining (Symbolic_Subdivision)#
          if (!is.null(previous_annot_id) && !is.null(level_hierarchy[[level$name]])) {#
            ref_attrs$PREVIOUS_ANNOTATION <- previous_annot_id#
          }#
          ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
          xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
          # Update for next iteration#
          annotation_map[[item_id]] <- paste0("a", item_id)#
          previous_annot_id <- paste0("a", item_id)#
        }#
      }#
    }#
  }#
  # Write the XML to file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}#
#
# Example usage:#
# convert_emu_to_eaf("msajc012_annot.json", "msajc012.eaf")
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf")
library(jsonlite)#
library(xml2)#
library(dplyr)#
library(purrr)#
#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL) {#
  # If no output file specified, create one with .eaf extension#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read the JSON file#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  # Extract media file if not provided#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create XML document#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z"),#
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  # Add MEDIA_DESCRIPTOR if media file exists#
  if (!is.null(media_file)) {#
    media_url <- if (grepl("^/", media_file) || grepl("^[A-Za-z]:", media_file)) {#
      paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    } else {#
      paste0("file://", file.path(getwd(), media_file))#
    }#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Build hierarchy map from links#
  parent_child_map <- list()  # child_id -> parent_id#
  children_map <- list()      # parent_id -> list of child_ids#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      # Store parent-child relationship#
      parent_child_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Build level hierarchy - determine which levels depend on which#
  level_hierarchy <- list()#
  level_items <- list()#
  for (level in emu_data$levels) {#
    level_items[[level$name]] <- sapply(level$items, function(x) as.character(x$id))#
    # Check if any items in this level have parents in other levels#
    parent_levels <- c()#
    for (item in level$items) {#
      parent_id <- parent_child_map[[as.character(item$id)]]#
      if (!is.null(parent_id)) {#
        # Find which level the parent belongs to#
        for (other_level in emu_data$levels) {#
          if (any(sapply(other_level$items, function(x) as.character(x$id) == parent_id))) {#
            if (!(other_level$name %in% parent_levels)) {#
              parent_levels <- c(parent_levels, other_level$name)#
            }#
            break#
          }#
        }#
      }#
    }#
    if (length(parent_levels) > 0) {#
      # Use the first parent level found#
      level_hierarchy[[level$name]] <- parent_levels[1]#
    }#
  }#
  # Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  # Collect all time points from SEGMENT and EVENT items#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  # Create time slots for unique time points#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Add standard constraints#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Create linguistic types#
  for (level in emu_data$levels) {#
    if (level$type == "ITEM") {#
      # ITEM types should be non-time-alignable with appropriate constraint#
      constraint <- if (!is.null(level_hierarchy[[level$name]])) {#
        "Symbolic_Subdivision"#
      } else {#
        "Symbolic_Association"#
      }#
      xml_add_child(doc, "LINGUISTIC_TYPE",#
                    LINGUISTIC_TYPE_ID = paste0(level$name, "_type"),#
                    TIME_ALIGNABLE = "false",#
                    CONSTRAINTS = constraint)#
    } else {#
      xml_add_child(doc, "LINGUISTIC_TYPE",#
                    LINGUISTIC_TYPE_ID = paste0(level$name, "_type"),#
                    TIME_ALIGNABLE = "true")#
    }#
  }#
  # Track created annotations#
  annotation_map <- list()#
  # Create tiers - first pass for time-aligned annotations#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      tier_attrs <- list(#
        TIER_ID = level$name,#
        LINGUISTIC_TYPE_REF = paste0(level$name, "_type")#
      )#
      # Add parent reference if exists#
      if (!is.null(level_hierarchy[[level$name]])) {#
        tier_attrs$PARENT_REF <- level_hierarchy[[level$name]]#
      }#
      tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
      # Add annotations#
      for (item in level$items) {#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        # Get annotation value#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          # Combine multiple label values if they exist#
          label_values <- sapply(item$labels, function(l) l$value)#
          annot_value <- paste(label_values, collapse = "; ")#
        }#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = paste0("a", item$id),#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
          xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          # Events typically have the same start and end time#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = paste0("a", item$id),#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(point_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(point_ms)]])#
          xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        }#
        annotation_map[[as.character(item$id)]] <- paste0("a", item$id)#
      }#
    }#
  }#
  # Second pass - create ITEM tiers with REF_ANNOTATIONs#
  for (level in emu_data$levels) {#
    if (level$type == "ITEM") {#
      tier_attrs <- list(#
        TIER_ID = level$name,#
        LINGUISTIC_TYPE_REF = paste0(level$name, "_type")#
      )#
      # Add parent tier reference if exists#
      if (!is.null(level_hierarchy[[level$name]])) {#
        tier_attrs$PARENT_REF <- level_hierarchy[[level$name]]#
      }#
      tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
      # Group items by parent for proper sequencing#
      items_by_parent <- list()#
      for (item in level$items) {#
        item_id <- as.character(item$id)#
        parent_id <- parent_child_map[[item_id]]#
        if (is.null(parent_id)) {#
          parent_id <- "NO_PARENT"#
        }#
        if (is.null(items_by_parent[[parent_id]])) {#
          items_by_parent[[parent_id]] <- list()#
        }#
        items_by_parent[[parent_id]] <- append(items_by_parent[[parent_id]], list(item))#
      }#
      # Create REF_ANNOTATIONs#
      for (parent_id in names(items_by_parent)) {#
        items <- items_by_parent[[parent_id]]#
        previous_annot_id <- NULL#
        for (i in seq_along(items)) {#
          item <- items[[i]]#
          item_id <- as.character(item$id)#
          annotation <- xml_add_child(tier, "ANNOTATION")#
          # Get annotation value#
          annot_value <- ""#
          if (!is.null(item$labels) && length(item$labels) > 0) {#
            label_values <- sapply(item$labels, function(l) l$value)#
            annot_value <- paste(label_values, collapse = "; ")#
          }#
          # Create REF_ANNOTATION#
          ref_attrs <- list(#
            ANNOTATION_ID = paste0("a", item_id)#
          )#
          # Add parent reference if exists#
          if (parent_id != "NO_PARENT" && !is.null(annotation_map[[parent_id]])) {#
            ref_attrs$ANNOTATION_REF <- annotation_map[[parent_id]]#
          }#
          # Add previous annotation reference for chaining (Symbolic_Subdivision)#
          if (!is.null(previous_annot_id) && !is.null(level_hierarchy[[level$name]])) {#
            ref_attrs$PREVIOUS_ANNOTATION <- previous_annot_id#
          }#
          ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
          xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
          # Update for next iteration#
          annotation_map[[item_id]] <- paste0("a", item_id)#
          previous_annot_id <- paste0("a", item_id)#
        }#
      }#
    }#
  }#
  # Write the XML to file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}#
#
# Example usage:#
# convert_emu_to_eaf("msajc012_annot.json", "msajc012.eaf")
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf")
library(jsonlite)#
library(xml2)#
#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL) {#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create document#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z"),#
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file)) {#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Build link maps#
  parent_map <- list()#
  children_map <- list()#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Store annotation IDs and level info#
  annotation_map <- list()#
  level_map <- list()#
  # Map items to their levels#
  for (level in emu_data$levels) {#
    for (item in level$items) {#
      level_map[[as.character(item$id)]] <- level$name#
    }#
  }#
  # First, create all tiers with time-aligned annotations#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      # Create tier#
      tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = "default-lt")#
      for (item in level$items) {#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          annot_value <- item$labels[[1]]$value#
        }#
        ann_id <- paste0("a", item$id)#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = ann_id,#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
        } else {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = ann_id,#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(point_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(point_ms)]])#
        }#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        annotation_map[[as.character(item$id)]] <- ann_id#
      }#
    }#
  }#
  # Now create ITEM tiers with REF_ANNOTATIONs#
  for (level in emu_data$levels) {#
    if (level$type == "ITEM") {#
      # Find a suitable parent tier#
      parent_tier <- NULL#
      for (item in level$items) {#
        parent_id <- parent_map[[as.character(item$id)]]#
        if (!is.null(parent_id) && !is.null(level_map[[parent_id]])) {#
          parent_tier <- level_map[[parent_id]]#
          break#
        }#
      }#
      # Create tier with parent reference if found#
      tier_attrs <- list(TIER_ID = level$name)#
      if (!is.null(parent_tier)) {#
        tier_attrs$PARENT_REF <- parent_tier#
        tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-subdivision"#
      } else {#
        # Find any time-aligned annotation to reference#
        for (item in level$items) {#
          parent_id <- parent_map[[as.character(item$id)]]#
          if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
            tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
            break#
          }#
        }#
        if (is.null(tier_attrs$LINGUISTIC_TYPE_REF)) {#
          tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
        }#
      }#
      tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
      # Add annotations#
      prev_annotation_id <- NULL#
      for (item in level$items) {#
        item_id <- as.character(item$id)#
        parent_id <- parent_map[[item_id]]#
        # Find a valid parent annotation#
        parent_ann_id <- NULL#
        if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
          parent_ann_id <- annotation_map[[parent_id]]#
        } else {#
          # Try to find any annotation to reference#
          # Use first available annotation from time-aligned tiers#
          if (length(annotation_map) > 0) {#
            parent_ann_id <- annotation_map[[1]]#
          }#
        }#
        if (!is.null(parent_ann_id)) {#
          annotation <- xml_add_child(tier, "ANNOTATION")#
          # Get all label values#
          annot_value <- ""#
          if (!is.null(item$labels) && length(item$labels) > 0) {#
            label_values <- sapply(item$labels, function(l) l$value)#
            annot_value <- paste(label_values, collapse = "; ")#
          }#
          ann_id <- paste0("a", item_id)#
          ref_attrs <- list(#
            ANNOTATION_ID = ann_id,#
            ANNOTATION_REF = parent_ann_id#
          )#
          # Add previous annotation for chaining if using subdivision#
          if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
            ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
          }#
          ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
          xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
          annotation_map[[item_id]] <- ann_id#
          prev_annotation_id <- ann_id#
        }#
      }#
    }#
  }#
  # Add linguistic types#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  # Add constraints#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf")
library(XML)#
library(jsonlite)#
#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL,#
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL, align_items = FALSE) {#
#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
#
  # Create document#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z"),#
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
#
  if (!is.null(media_file)) {#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
#
  # Build link maps (not used in this example, but kept for completeness)#
  parent_map <- list()#
  children_map <- list()#
#
  # Iterate through tiers (assuming your JSON has a "tiers" structure)#
  for (tier_data in emu_data$tiers) {#
#
    tier <- xml_add_child(doc, "TIER", TIER_ID = tier_data$tier_id)#
    xml_add_child(tier, "PARTICIPANT", tier_data$participant) # Add participant if present#
    xml_add_child(tier, "ANNOTATOR", tier_data$annotator) # Add annotator if present#
#
    # Iterate through annotations within the tier#
    for (annotation in tier_data$annotations) {#
#
      if (annotation$annotation_type == "ITEM" && align_items) {#
        # Find the earliest start time and latest end time of dominated SEGMENT or EVENT annotations.#
#
        dominated_segments <- annotation$dominated_by %>% filter(annotation_type == "SEGMENT")#
        dominated_events <- annotation$dominated_by %>% filter(annotation_type == "EVENT")#
#
        all_dominated <- c(dominated_segments, dominated_events)#
        start_time <- min(all_dominated$start_time) # Assuming start_time is a field#
        end_time <- max(all_dominated$end_time) # Assuming end_time is a field#
#
        # Create ALIGNABLE_ANNOTATION#
        alignable_annotation <- xml_add_child(tier, "ALIGNABLE_ANNOTATION",#
                                              TIME_SLOT = paste0("ts_", length(tier$annotations) + 1), # Generate a unique ID#
                                              START_TIME = start_time,#
                                              END_TIME = end_time)#
#
      } else {#
        # Process the annotation as a regular annotation (your existing code)#
        xml_add_child(tier, "ANNOTATION",#
                      TIME_SLOT = paste0("ts_", length(tier$annotations) + 1),#
                      ALIGNMENT_TIME = annotation$start_time, # Assuming start_time is a field#
                      annotation$text)  # Add annotation text or other properties#
#
      }#
    }#
  }#
  # Write file#
  write_xml(doc, eaf_file)#
#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf")
library(jsonlite)#
library(xml2)#
#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL) {#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create document#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z"),#
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file)) {#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Build link maps#
  parent_map <- list()#
  children_map <- list()#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Store annotation IDs and level info#
  annotation_map <- list()#
  level_map <- list()#
  # Map items to their levels#
  for (level in emu_data$levels) {#
    for (item in level$items) {#
      level_map[[as.character(item$id)]] <- level$name#
    }#
  }#
  # First, create all tiers with time-aligned annotations#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      # Create tier#
      tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = "default-lt")#
      for (item in level$items) {#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          annot_value <- item$labels[[1]]$value#
        }#
        ann_id <- paste0("a", item$id)#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = ann_id,#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
        } else {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = ann_id,#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(point_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(point_ms)]])#
        }#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        annotation_map[[as.character(item$id)]] <- ann_id#
      }#
    }#
  }#
  # Now create ITEM tiers with REF_ANNOTATIONs#
  for (level in emu_data$levels) {#
    if (level$type == "ITEM") {#
      # Find a suitable parent tier#
      parent_tier <- NULL#
      for (item in level$items) {#
        parent_id <- parent_map[[as.character(item$id)]]#
        if (!is.null(parent_id) && !is.null(level_map[[parent_id]])) {#
          parent_tier <- level_map[[parent_id]]#
          break#
        }#
      }#
      # Create tier with parent reference if found#
      tier_attrs <- list(TIER_ID = level$name)#
      if (!is.null(parent_tier)) {#
        tier_attrs$PARENT_REF <- parent_tier#
        tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-subdivision"#
      } else {#
        # Find any time-aligned annotation to reference#
        for (item in level$items) {#
          parent_id <- parent_map[[as.character(item$id)]]#
          if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
            tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
            break#
          }#
        }#
        if (is.null(tier_attrs$LINGUISTIC_TYPE_REF)) {#
          tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
        }#
      }#
      tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
      # Add annotations#
      prev_annotation_id <- NULL#
      for (item in level$items) {#
        item_id <- as.character(item$id)#
        parent_id <- parent_map[[item_id]]#
        # Find a valid parent annotation#
        parent_ann_id <- NULL#
        if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
          parent_ann_id <- annotation_map[[parent_id]]#
        } else {#
          # Try to find any annotation to reference#
          # Use first available annotation from time-aligned tiers#
          if (length(annotation_map) > 0) {#
            parent_ann_id <- annotation_map[[1]]#
          }#
        }#
        if (!is.null(parent_ann_id)) {#
          annotation <- xml_add_child(tier, "ANNOTATION")#
          # Get all label values#
          annot_value <- ""#
          if (!is.null(item$labels) && length(item$labels) > 0) {#
            label_values <- sapply(item$labels, function(l) l$value)#
            annot_value <- paste(label_values, collapse = "; ")#
          }#
          ann_id <- paste0("a", item_id)#
          ref_attrs <- list(#
            ANNOTATION_ID = ann_id,#
            ANNOTATION_REF = parent_ann_id#
          )#
          # Add previous annotation for chaining if using subdivision#
          if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
            ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
          }#
          ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
          xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
          annotation_map[[item_id]] <- ann_id#
          prev_annotation_id <- ann_id#
        }#
      }#
    }#
  }#
  # Add linguistic types#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  # Add constraints#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf")
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL) {#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create document#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z"),#
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file)) {#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Build link maps#
  parent_map <- list()#
  children_map <- list()#
  # Add TIME_ORDER and TIME_SLOTs based on the citation provided.#
  time_slots <- c("ts1" = 610, "ts2" = 1950, "ts3" = 1950, "ts4" = NA, "ts5" = NA, "ts6" = 8420)#
  for (i in seq_along(time_slots)) {#
    slot_id <- names(time_slots)[i]#
    value <- time_slots[i]#
    if (!is.na(value)) {#
      xml_add_child(doc, "TIME_SLOT", TIME_SLOT_ID = slot_id, TIME_VALUE = as.character(value))#
    } else {#
      xml_add_child(doc, "TIME_SLOT", TIME_SLOT_ID = slot_id)#
    }#
  }#
  # Add TIERs and ANNOTATIONs based on the citation provided.#
  tiers <- list("Tier1" = c("ts1", "ts2", "ts3"), "Tier2" = c("ts4", "ts5", "ts6"))#
  for (tier_name in names(tiers)) {#
    tier <- xml_add_child(doc, "TIER", TIER_ID = tier_name)#
    participants <- list()#
    annotators <- list()#
    for (slot_id in tiers[[tier_name]]) {#
      if (!is.na(time_slots[slot_id])) {#
        xml_add_child(tier, "TIME_SLOT", TIME_SLOT_ID = slot_id, TIME_VALUE = as.character(time_slots[slot_id]))#
      } else {#
        xml_add_child(tier, "TIME_SLOT", TIME_SLOT_ID = slot_id)#
      }#
    }#
  }#
  # Add ALIGNABLE_ANNOTATIONs based on the user's request.#
  if (align_items) {#
    for (item in emu_data$items) {#
      parent_slot <- item$parent_slot#
      start_time <- min(unlist(lapply(item$children, function(child) child$start_time)))#
      end_time <- max(unlist(lapply(item$children, function(child) child$end_time)))#
      if (!is.null(parent_slot)) {#
        xml_add_child(doc, "ALIGNABLE_ANNOTATION", ANALYSING_CUE = item$label, START_TIME_SLOT_REF = parent_slot, END_TIME_SLOT_REF = parent_slot)#
      } else {#
        xml_add_child(doc, "ALIGNABLE_ANNOTATION", ANALYSING_CUE = item$label, START_TIME_SLOT_REF = start_time, END_TIME_SLOT_REF = end_time)#
      }#
    }#
  }#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf")
library(jsonlite)#
library(xml2)#
#
onvert_emu_to_eaf <- function(json_file, eaf_file = NULL,#
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL, align_items = FALSE) { # Added align_items parameter#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create document#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z"),#
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file)) {#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Build link maps#
  parent_map <- list()#
  children_map <- list()#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Store annotation IDs and level info#
  annotation_map <- list()#
  level_map <- list()#
  # Map items to their levels#
  for (level in emu_data$levels) {#
    for (item in level$items) {#
      level_map[[as.character(item$id)]] <- level$name#
    }#
  }#
  # First, create all tiers with time-aligned annotations#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      # Create tier#
      tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = "default-lt")#
      for (item in level$items) {#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          annot_value <- item$labels[[1]]$value#
        }#
        ann_id <- paste0("a", item$id)#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = ann_id,#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
        } else {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = ann_id,#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(point_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(point_ms)]])#
        }#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        annotation_map[[as.character(item$id)]] <- ann_id#
      }#
    }#
  }#
# Now create ITEM tiers with REF_ANNOTATIONs or ALIGNABLE_ANNOTATIONs#
for (level in emu_data$levels) {#
  if (level$type == "ITEM") {#
    # Find a suitable parent tier#
    parent_tier <- NULL#
    for (item in level$items) {#
      parent_id <- parent_map[[as.character(item$id)]]#
      if (!is.null(parent_id) && !is.null(level_map[[parent_id]])) {#
        parent_tier <- level_map[[parent_id]]#
        break#
      }#
    }#
#
    # Create tier with parent reference if found#
    tier_attrs <- list(TIER_ID = level$name)#
#
    if (!is.null(parent_tier)) {#
      tier_attrs$PARENT_REF <- parent_tier#
      tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-subdivision"#
    } else {#
      # Find any time-aligned annotation to reference#
      for (item in level$items) {#
        parent_id <- parent_map[[as.character(item$id)]]#
        if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
          tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
          break#
        }#
      }#
      if (is.null(tier_attrs$LINGUISTIC_TYPE_REF)) {#
        tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
      }#
    }#
#
    tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
#
    # Add annotations#
    prev_annotation_id <- NULL#
#
    for (item in level$items) {#
      item_id <- as.character(item$id)#
      parent_id <- parent_map[[item_id]]#
#
      if (align_items) {#
        # If align_items is TRUE, find all child SEGMENT/EVENT annotations#
        child_ids <- children_map[[item_id]]#
        if (!is.null(child_ids) && length(child_ids) > 0) {#
          child_start_times <- c()#
          child_end_times <- c()#
#
          for (child_id in child_ids) {#
            child_ann_id <- annotation_map[[as.character(child_id)]]#
            if (!is.null(child_ann_id)) {#
              # Extract start and end times from child annotations#
              # This assumes child annotations are ALIGNABLE_ANNOTATIONs#
              child_annot <- xml_find_all(doc, paste0("//ANNOTATION[@ANNOTATION_ID='", child_ann_id, "']/ALIGNABLE_ANNOTATION"))#
              if (length(child_annot) > 0) {#
                start_ts <- xml_attr(child_annot[[1]], "TIME_SLOT_REF1")#
                end_ts <- xml_attr(child_annot[[1]], "TIME_SLOT_REF2")#
                start_time <- as.numeric(substr(start_ts, 3, nchar(start_ts)))#
                end_time <- as.numeric(substr(end_ts, 3, nchar(end_ts)))#
                child_start_times <- c(child_start_times, start_time)#
                child_end_times <- c(child_end_times, end_time)#
              }#
            }#
          }#
#
          if (length(child_start_times) > 0 && length(child_end_times) > 0) {#
            min_start <- min(child_start_times)#
            max_end <- max(child_end_times)#
#
            # Create ALIGNABLE_ANNOTATION for ITEM#
            annotation <- xml_add_child(tier, "ANNOTATION")#
            ann_id <- paste0("a", item_id)#
            alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                      ANNOTATION_ID = ann_id,#
                                      TIME_SLOT_REF1 = time_slot_map[[as.character(min_start)]],#
                                      TIME_SLOT_REF2 = time_slot_map[[as.character(max_end)]])#
#
            # Get annotation value#
            annot_value <- ""#
            if (!is.null(item$labels) && length(item$labels) > 0) {#
              label_values <- sapply(item$labels, function(l) l$value)#
              annot_value <- paste(label_values, collapse = "; ")#
            }#
            xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
            annotation_map[[item_id]] <- ann_id#
            prev_annotation_id <- ann_id#
          }#
        }#
      } else {#
        # Original logic for REF_ANNOTATION#
        parent_ann_id <- NULL#
        if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
          parent_ann_id <- annotation_map[[parent_id]]#
        } else {#
          if (length(annotation_map) > 0) {#
            parent_ann_id <- annotation_map[[1]]#
          }#
        }#
#
        if (!is.null(parent_ann_id)) {#
          annotation <- xml_add_child(tier, "ANNOTATION")#
#
          annot_value <- ""#
          if (!is.null(item$labels) && length(item$labels) > 0) {#
            label_values <- sapply(item$labels, function(l) l$value)#
            annot_value <- paste(label_values, collapse = "; ")#
          }#
#
          ann_id <- paste0("a", item_id)#
#
          ref_attrs <- list(#
            ANNOTATION_ID = ann_id,#
            ANNOTATION_REF = parent_ann_id#
          )#
#
          if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
            ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
          }#
#
          ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
          xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
#
          annotation_map[[item_id]] <- ann_id#
          prev_annotation_id <- ann_id#
        }#
      }#
    }#
  }#
}#
  # Add linguistic types#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  # Add constraints#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf")
library(jsonlite)#
library(xml2)#
#
onvert_emu_to_eaf <- function(json_file, eaf_file = NULL,#
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL, align_items = FALSE) { # Added align_items parameter#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create document#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z"),#
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file)) {#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Build link maps#
  parent_map <- list()#
  children_map <- list()#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Store annotation IDs and level info#
  annotation_map <- list()#
  level_map <- list()#
  # Map items to their levels#
  for (level in emu_data$levels) {#
    for (item in level$items) {#
      level_map[[as.character(item$id)]] <- level$name#
    }#
  }#
  # First, create all tiers with time-aligned annotations#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      # Create tier#
      tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = "default-lt")#
      for (item in level$items) {#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          annot_value <- item$labels[[1]]$value#
        }#
        ann_id <- paste0("a", item$id)#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = ann_id,#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
        } else {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = ann_id,#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(point_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(point_ms)]])#
        }#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        annotation_map[[as.character(item$id)]] <- ann_id#
      }#
    }#
  }#
# Now create ITEM tiers with REF_ANNOTATIONs or ALIGNABLE_ANNOTATIONs#
for (level in emu_data$levels) {#
  if (level$type == "ITEM") {#
    # Find a suitable parent tier#
    parent_tier <- NULL#
    for (item in level$items) {#
      parent_id <- parent_map[[as.character(item$id)]]#
      if (!is.null(parent_id) && !is.null(level_map[[parent_id]])) {#
        parent_tier <- level_map[[parent_id]]#
        break#
      }#
    }#
#
    # Create tier with parent reference if found#
    tier_attrs <- list(TIER_ID = level$name)#
#
    if (!is.null(parent_tier)) {#
      tier_attrs$PARENT_REF <- parent_tier#
      tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-subdivision"#
    } else {#
      # Find any time-aligned annotation to reference#
      for (item in level$items) {#
        parent_id <- parent_map[[as.character(item$id)]]#
        if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
          tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
          break#
        }#
      }#
      if (is.null(tier_attrs$LINGUISTIC_TYPE_REF)) {#
        tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
      }#
    }#
#
    tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
#
    # Add annotations#
    prev_annotation_id <- NULL#
#
    for (item in level$items) {#
      item_id <- as.character(item$id)#
      parent_id <- parent_map[[item_id]]#
#
      if (align_items) {#
        # If align_items is TRUE, find all child SEGMENT/EVENT annotations#
        child_ids <- children_map[[item_id]]#
        if (!is.null(child_ids) && length(child_ids) > 0) {#
          child_start_times <- c()#
          child_end_times <- c()#
#
          for (child_id in child_ids) {#
            child_ann_id <- annotation_map[[as.character(child_id)]]#
            if (!is.null(child_ann_id)) {#
              # Extract start and end times from child annotations#
              # This assumes child annotations are ALIGNABLE_ANNOTATIONs#
              child_annot <- xml_find_all(doc, paste0("//ANNOTATION[@ANNOTATION_ID='", child_ann_id, "']/ALIGNABLE_ANNOTATION"))#
              if (length(child_annot) > 0) {#
                start_ts <- xml_attr(child_annot[[1]], "TIME_SLOT_REF1")#
                end_ts <- xml_attr(child_annot[[1]], "TIME_SLOT_REF2")#
                start_time <- as.numeric(substr(start_ts, 3, nchar(start_ts)))#
                end_time <- as.numeric(substr(end_ts, 3, nchar(end_ts)))#
                child_start_times <- c(child_start_times, start_time)#
                child_end_times <- c(child_end_times, end_time)#
              }#
            }#
          }#
#
          if (length(child_start_times) > 0 && length(child_end_times) > 0) {#
            min_start <- min(child_start_times)#
            max_end <- max(child_end_times)#
#
            # Create ALIGNABLE_ANNOTATION for ITEM#
            annotation <- xml_add_child(tier, "ANNOTATION")#
            ann_id <- paste0("a", item_id)#
            alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                      ANNOTATION_ID = ann_id,#
                                      TIME_SLOT_REF1 = time_slot_map[[as.character(min_start)]],#
                                      TIME_SLOT_REF2 = time_slot_map[[as.character(max_end)]])#
#
            # Get annotation value#
            annot_value <- ""#
            if (!is.null(item$labels) && length(item$labels) > 0) {#
              label_values <- sapply(item$labels, function(l) l$value)#
              annot_value <- paste(label_values, collapse = "; ")#
            }#
            xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
            annotation_map[[item_id]] <- ann_id#
            prev_annotation_id <- ann_id#
          }#
        }#
      } else {#
        # Original logic for REF_ANNOTATION#
        parent_ann_id <- NULL#
        if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
          parent_ann_id <- annotation_map[[parent_id]]#
        } else {#
          if (length(annotation_map) > 0) {#
            parent_ann_id <- annotation_map[[1]]#
          }#
        }#
#
        if (!is.null(parent_ann_id)) {#
          annotation <- xml_add_child(tier, "ANNOTATION")#
#
          annot_value <- ""#
          if (!is.null(item$labels) && length(item$labels) > 0) {#
            label_values <- sapply(item$labels, function(l) l$value)#
            annot_value <- paste(label_values, collapse = "; ")#
          }#
#
          ann_id <- paste0("a", item_id)#
#
          ref_attrs <- list(#
            ANNOTATION_ID = ann_id,#
            ANNOTATION_REF = parent_ann_id#
          )#
#
          if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
            ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
          }#
#
          ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
          xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
#
          annotation_map[[item_id]] <- ann_id#
          prev_annotation_id <- ann_id#
        }#
      }#
    }#
  }#
}#
  # Add linguistic types#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  # Add constraints#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf")
