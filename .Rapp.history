  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = date_string, #
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file) && file.exists(media_file)) {#
    # Paths (relative path is essential for portability)#
    relative_url <- basename(media_file)#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    # 1. Add MEDIA_DESCRIPTOR (Minimal valid set for EAF 3.0)#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = media_mimetype,#
                  RELATIVE_MEDIA_URL = relative_url)#
    # 2. Add LINKED_FILE_DESCRIPTOR (Minimal valid set for EAF 3.0, satisfying LINK_URL requirement)#
    xml_add_child(header, "LINKED_FILE_DESCRIPTOR",#
                  LINK_URL = media_url,#
                  MIME_TYPE = media_mimetype)#
  }#
  # Build link maps (No change)#
  parent_map <- list()#
  children_map <- list()#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Store level info and map level name to type (No change)#
  level_map <- list() #
  level_type_map <- list()#
  for (level in emu_data$levels) {#
    level_type_map[[level$name]] <- level$type#
    for (item in level$items) {#
      level_map[[as.character(item$id)]] <- level$name #
    }#
  }#
#
  # Create TIME_ORDER (No change)#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points (SEGMENT/EVENT + ITEM if align_items=TRUE) (No change)#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  if (align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          time_range <- get_item_time_range(item_id, emu_data, children_map, time_slot_map, level_map, level_type_map)#
          if (!is.null(time_range)) {#
            all_time_points <- c(all_time_points, time_range$start, time_range$end)#
          }#
        }#
      }#
    }#
  }#
#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Store annotation IDs#
  annotation_map <- list()#
  # 1. Create all tiers with time-aligned annotations (SEGMENT, EVENT, and ITEM if align_items=TRUE) (No change)#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT") || (level$type == "ITEM" && align_items)) {#
      tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = "default-lt")#
      for (item in level$items) {#
        item_id <- as.character(item$id)#
        start_ms <- NULL#
        end_ms <- NULL#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          start_ms <- point_ms#
          end_ms <- point_ms#
        } else if (level$type == "ITEM" && align_items) {#
          time_range <- get_item_time_range(item_id, emu_data, children_map, time_slot_map, level_map, level_type_map)#
          if (is.null(time_range)) next#
          start_ms <- time_range$start#
          end_ms <- time_range$end#
        } else {#
          next #
        }#
#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        ann_id <- paste0("a", item_id)#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          label_values <- sapply(item$labels, function(l) l$value)#
          annot_value <- paste(label_values, collapse = "; ")#
        }#
        alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                 ANNOTATION_ID = ann_id,#
                                 TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                 TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        annotation_map[[item_id]] <- ann_id#
      }#
    }#
  }#
  # 2. Now create ITEM tiers with REF_ANNOTATIONs (only if align_items=FALSE) (No change)#
  if (!align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        parent_tier_name <- NULL#
        for (item in level$items) {#
          parent_id <- parent_map[[as.character(item$id)]]#
          if (!is.null(parent_id) && !is.null(level_map[[parent_id]])) {#
            parent_tier_name <- level_map[[parent_id]]#
            break#
          }#
        }#
        tier_attrs <- list(TIER_ID = level$name)#
        if (!is.null(parent_tier_name)) {#
          tier_attrs$PARENT_REF <- parent_tier_name#
          parent_level_obj <- emu_data$levels[[which(sapply(emu_data$levels, function(l) l$name == parent_tier_name))]]#
          if (!is.null(parent_level_obj) && parent_level_obj$type %in% c("SEGMENT", "EVENT")) {#
              tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-subdivision"#
          } else {#
              tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
          }#
        } else {#
          # Functional logic for root symbolic tiers (like Utterance)#
          tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
        }#
        tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
        prev_annotation_id <- NULL#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          parent_id <- parent_map[[item_id]]#
          parent_ann_id <- NULL#
          if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
            parent_ann_id <- annotation_map[[parent_id]]#
          }#
          if (tier_attrs$LINGUISTIC_TYPE_REF %in% c("symbolic-subdivision", "symbolic-association") && !is.null(parent_ann_id)) {#
            annotation <- xml_add_child(tier, "ANNOTATION")#
            annot_value <- ""#
            if (!is.null(item$labels) && length(item$labels) > 0) {#
              label_values <- sapply(item$labels, function(l) l$value)#
              annot_value <- paste(label_values, collapse = "; ")#
            }#
            ann_id <- paste0("a", item_id)#
            ref_attrs <- list(#
              ANNOTATION_ID = ann_id,#
              ANNOTATION_REF = parent_ann_id#
            )#
            if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
              ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
            }#
            ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
            xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
            annotation_map[[item_id]] <- ann_id#
            prev_annotation_id <- ann_id#
          } #
          else if (is.null(parent_tier_name) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-association") {#
            if (length(annotation_map) > 0) {#
              first_ann_id <- annotation_map[[1]] #
              annotation <- xml_add_child(tier, "ANNOTATION")#
              annot_value <- ""#
              if (!is.null(item$labels) && length(item$labels) > 0) {#
                label_values <- sapply(item$labels, function(l) l$value)#
                annot_value <- paste(label_values, collapse = "; ")#
              }#
              ann_id <- paste0("a", item_id)#
              ref_attrs <- list(#
                ANNOTATION_ID = ann_id,#
                ANNOTATION_REF = first_ann_id #
              )#
              ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
              xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
              annotation_map[[item_id]] <- ann_id#
            }#
          }#
        }#
      }#
    }#
  }#
  # Add linguistic types and constraints (No change)#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf",align_items=TRUE)
library(jsonlite)#
library(xml2)#
library(av)#
#
# Helper function to recursively find the time range for an ITEM annotation#
get_item_time_range <- function(item_id, emu_data, children_map, time_points_map, level_map, level_type_map) {#
  level_name <- level_map[[item_id]]#
  level_type <- level_type_map[[level_name]]#
  # Base case: if item_id belongs to a segment or event level (i.e., time-aligned)#
  if (level_type %in% c("SEGMENT", "EVENT")) { #
    level_list_index <- which(sapply(emu_data$levels, function(l) l$name == level_name))#
    level <- emu_data$levels[[level_list_index]]#
    item <- level$items[[which(sapply(level$items, function(i) as.character(i$id) == item_id))]]#
    if (level$type == "SEGMENT") {#
      start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
      end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
    } else { # EVENT#
      point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
      start_ms <- point_ms#
      end_ms <- point_ms#
    }#
    return(list(start = start_ms, end = end_ms))#
  }#
  # Recursive case: find children's time ranges#
  children_ids <- children_map[[item_id]]#
  if (is.null(children_ids)) {#
    return(NULL) #
  }#
  min_start <- Inf#
  max_end <- -Inf#
  for (child_id in children_ids) {#
    range <- get_item_time_range(child_id, emu_data, children_map, time_points_map, level_map, level_type_map)#
    if (!is.null(range)) {#
      min_start <- min(min_start, range$start)#
      max_end <- max(max_end, range$end)#
    }#
  }#
  if (is.infinite(min_start) || is.infinite(max_end)) {#
    return(NULL)#
  }#
  return(list(start = min_start, end = max_end))#
}#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL,#
                               align_items = FALSE) { #
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  # Set media_file if not provided (assume same directory)#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- file.path(dirname(json_file), basename(emu_data$annotates))#
  }#
  # --- MEDIA METADATA RETRIEVAL ---#
  media_mimetype <- "audio/x-wav" #
  # Create document#
  date_string <- format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z")#
  date_string <- sub("([+-][0-9]{2})([0-9]{2})$", "\\1:\\2", date_string) # Fix timezone format#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = date_string, #
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file) && file.exists(media_file)) {#
    # Paths (relative path is essential for portability)#
    relative_url <- basename(media_file)#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    # 1. Add MEDIA_DESCRIPTOR (Minimal valid set for EAF 3.0)#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = media_mimetype,#
                  RELATIVE_MEDIA_URL = relative_url)#
    # 2. Add LINKED_FILE_DESCRIPTOR #
    xml_add_child(header, "LINKED_FILE_DESCRIPTOR",#
                  LINK_URL = media_url,#
                  MIME_TYPE = media_mimetype)#
  }#
  # Build link maps (No change)#
  parent_map <- list()#
  children_map <- list()#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Store level info and map level name to type (No change)#
  level_map <- list() #
  level_type_map <- list()#
  for (level in emu_data$levels) {#
    level_type_map[[level$name]] <- level$type#
    for (item in level$items) {#
      level_map[[as.character(item$id)]] <- level$name #
    }#
  }#
#
  # Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points (SEGMENT/EVENT + ITEM if align_items=TRUE)#
  for (level in emu_data$levels) {#
    # NOTE: For EVENTs, we only collect the time value once for the base time slot list.#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  if (align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          time_range <- get_item_time_range(item_id, emu_data, children_map, time_slot_map, level_map, level_type_map)#
          if (!is.null(time_range)) {#
            all_time_points <- c(all_time_points, time_range$start, time_range$end)#
          }#
        }#
      }#
    }#
  }#
#
  # Create base time slots (unique time values)#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Store annotation IDs#
  annotation_map <- list()#
  # 1. Create all tiers with time-aligned annotations #
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT") || (level$type == "ITEM" && align_items)) {#
      tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = "default-lt")#
      for (item in level$items) {#
        item_id <- as.character(item$id)#
        start_ms <- NULL#
        end_ms <- NULL#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          start_ms <- point_ms#
          end_ms <- point_ms#
        } else if (level$type == "ITEM" && align_items) {#
          time_range <- get_item_time_range(item_id, emu_data, children_map, time_slot_map, level_map, level_type_map)#
          if (is.null(time_range)) next#
          start_ms <- time_range$start#
          end_ms <- time_range$end#
        } else {#
          next #
        }#
#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        ann_id <- paste0("a", item_id)#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          label_values <- sapply(item$labels, function(l) l$value)#
          annot_value <- paste(label_values, collapse = "; ")#
        }#
        # --- Time Slot References & EVENT Workaround ---#
        ref1_ts_id <- time_slot_map[[as.character(start_ms)]]#
        ref2_ts_id <- time_slot_map[[as.character(end_ms)]]#
        if (level$type == "EVENT") {#
            # WORKAROUND for point annotations: Create a second TIME_SLOT_ID#
            # that references the same time value, satisfying TIME_SLOT_REF1 != TIME_SLOT_REF2#
            ref2_ts_id <- paste0(ref1_ts_id, "_end_", ann_id) #
            # Append this new TIME_SLOT to the TIME_ORDER block immediately#
            xml_add_child(time_order, "TIME_SLOT", #
                          TIME_SLOT_ID = ref2_ts_id, #
                          TIME_VALUE = as.character(end_ms))#
        }#
        # --- End of Workaround ---#
        alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                 ANNOTATION_ID = ann_id,#
                                 TIME_SLOT_REF1 = ref1_ts_id,#
                                 TIME_SLOT_REF2 = ref2_ts_id)#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        annotation_map[[item_id]] <- ann_id#
      }#
    }#
  }#
  # 2. Now create ITEM tiers with REF_ANNOTATIONs (only if align_items=FALSE) (No change)#
  if (!align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        parent_tier_name <- NULL#
        for (item in level$items) {#
          parent_id <- parent_map[[as.character(item$id)]]#
          if (!is.null(parent_id) && !is.null(level_map[[parent_id]])) {#
            parent_tier_name <- level_map[[parent_id]]#
            break#
          }#
        }#
        tier_attrs <- list(TIER_ID = level$name)#
        if (!is.null(parent_tier_name)) {#
          tier_attrs$PARENT_REF <- parent_tier_name#
          parent_level_obj <- emu_data$levels[[which(sapply(emu_data$levels, function(l) l$name == parent_tier_name))]]#
          if (!is.null(parent_level_obj) && parent_level_obj$type %in% c("SEGMENT", "EVENT")) {#
              tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-subdivision"#
          } else {#
              tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
          }#
        } else {#
          tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
        }#
        tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
        prev_annotation_id <- NULL#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          parent_id <- parent_map[[item_id]]#
          parent_ann_id <- NULL#
          if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
            parent_ann_id <- annotation_map[[parent_id]]#
          }#
          if (tier_attrs$LINGUISTIC_TYPE_REF %in% c("symbolic-subdivision", "symbolic-association") && !is.null(parent_ann_id)) {#
            annotation <- xml_add_child(tier, "ANNOTATION")#
            annot_value <- ""#
            if (!is.null(item$labels) && length(item$labels) > 0) {#
              label_values <- sapply(item$labels, function(l) l$value)#
              annot_value <- paste(label_values, collapse = "; ")#
            }#
            ann_id <- paste0("a", item_id)#
            ref_attrs <- list(#
              ANNOTATION_ID = ann_id,#
              ANNOTATION_REF = parent_ann_id#
            )#
            if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
              ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
            }#
            ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
            xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
            annotation_map[[item_id]] <- ann_id#
            prev_annotation_id <- ann_id#
          } #
          else if (is.null(parent_tier_name) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-association") {#
            if (length(annotation_map) > 0) {#
              first_ann_id <- annotation_map[[1]] #
              annotation <- xml_add_child(tier, "ANNOTATION")#
              annot_value <- ""#
              if (!is.null(item$labels) && length(item$labels) > 0) {#
                label_values <- sapply(item$labels, function(l) l$value)#
                annot_value <- paste(label_values, collapse = "; ")#
              }#
              ann_id <- paste0("a", item_id)#
              ref_attrs <- list(#
                ANNOTATION_ID = ann_id,#
                ANNOTATION_REF = first_ann_id #
              )#
              ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
              xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
              annotation_map[[item_id]] <- ann_id#
            }#
          }#
        }#
      }#
    }#
  }#
  # Add linguistic types and constraints (No change)#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf",align_items=TRUE)
library(jsonlite)#
library(xml2)#
library(av)#
#
# Helper function to recursively find the time range for an ITEM annotation#
get_item_time_range <- function(item_id, emu_data, children_map, time_points_map, level_map, level_type_map) {#
  level_name <- level_map[[item_id]]#
  level_type <- level_type_map[[level_name]]#
  # Base case: if item_id belongs to a segment or event level (i.e., time-aligned)#
  if (level_type %in% c("SEGMENT", "EVENT")) { #
    level_list_index <- which(sapply(emu_data$levels, function(l) l$name == level_name))#
    level <- emu_data$levels[[level_list_index]]#
    item <- level$items[[which(sapply(level$items, function(i) as.character(i$id) == item_id))]]#
    if (level$type == "SEGMENT") {#
      start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
      end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
    } else { # EVENT: Use 1ms duration for time-span calculation for parent ITEMs#
      point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
      start_ms <- point_ms#
      end_ms <- point_ms + 1 # Use 1ms duration for time range calculation#
    }#
    return(list(start = start_ms, end = end_ms))#
  }#
  # Recursive case: find children's time ranges#
  children_ids <- children_map[[item_id]]#
  if (is.null(children_ids)) {#
    return(NULL) #
  }#
  min_start <- Inf#
  max_end <- -Inf#
  for (child_id in children_ids) {#
    range <- get_item_time_range(child_id, emu_data, children_map, time_points_map, level_map, level_type_map)#
    if (!is.null(range)) {#
      min_start <- min(min_start, range$start)#
      max_end <- max(max_end, range$end)#
    }#
  }#
  if (is.infinite(min_start) || is.infinite(max_end)) {#
    return(NULL)#
  }#
  return(list(start = min_start, end = max_end))#
}#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL,#
                               align_items = FALSE) { #
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  # Set media_file if not provided (assume same directory)#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- file.path(dirname(json_file), basename(emu_data$annotates))#
  }#
  # --- MEDIA METADATA RETRIEVAL ---#
  media_mimetype <- "audio/x-wav" #
  # Create document#
  date_string <- format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z")#
  date_string <- sub("([+-][0-9]{2})([0-9]{2})$", "\\1:\\2", date_string) # Fix timezone format#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = date_string, #
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file) && file.exists(media_file)) {#
    # Paths #
    relative_url <- basename(media_file)#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    # 1. Add MEDIA_DESCRIPTOR #
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = media_mimetype,#
                  RELATIVE_MEDIA_URL = relative_url)#
    # 2. Add LINKED_FILE_DESCRIPTOR #
    xml_add_child(header, "LINKED_FILE_DESCRIPTOR",#
                  LINK_URL = media_url,#
                  MIME_TYPE = media_mimetype)#
  }#
  # Build link maps (No change)#
  parent_map <- list()#
  children_map <- list()#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Store level info and map level name to type (No change)#
  level_map <- list() #
  level_type_map <- list()#
  for (level in emu_data$levels) {#
    level_type_map[[level$name]] <- level$type#
    for (item in level$items) {#
      level_map[[as.character(item$id)]] <- level$name #
    }#
  }#
#
  # Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points (SEGMENT/EVENT + ITEM if align_items=TRUE)#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          # KEY FIX: Collect the start point and the padded end point (point_ms + 1ms)#
          all_time_points <- c(all_time_points, point_ms, point_ms + 1) #
        }#
      }#
    }#
  }#
  if (align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          time_range <- get_item_time_range(item_id, emu_data, children_map, time_slot_map, level_map, level_type_map)#
          if (!is.null(time_range)) {#
            all_time_points <- c(all_time_points, time_range$start, time_range$end)#
          }#
        }#
      }#
    }#
  }#
#
  # Create time slots (unique time values)#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Store annotation IDs#
  annotation_map <- list()#
  # 1. Create all tiers with time-aligned annotations #
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT") || (level$type == "ITEM" && align_items)) {#
      tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = "default-lt")#
      for (item in level$items) {#
        item_id <- as.character(item$id)#
        start_ms <- NULL#
        end_ms <- NULL#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          # KEY FIX: Assign a 1ms duration for validation compliance#
          start_ms <- point_ms#
          end_ms <- point_ms + 1#
        } else if (level$type == "ITEM" && align_items) {#
          time_range <- get_item_time_range(item_id, emu_data, children_map, time_slot_map, level_map, level_type_map)#
          if (is.null(time_range)) next#
          start_ms <- time_range$start#
          end_ms <- time_range$end#
        } else {#
          next #
        }#
#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        ann_id <- paste0("a", item_id)#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          label_values <- sapply(item$labels, function(l) l$value)#
          annot_value <- paste(label_values, collapse = "; ")#
        }#
        # Use the two now-different time slots#
        ref1_ts_id <- time_slot_map[[as.character(start_ms)]]#
        ref2_ts_id <- time_slot_map[[as.character(end_ms)]]#
        alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                 ANNOTATION_ID = ann_id,#
                                 TIME_SLOT_REF1 = ref1_ts_id,#
                                 TIME_SLOT_REF2 = ref2_ts_id)#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        annotation_map[[item_id]] <- ann_id#
      }#
    }#
  }#
  # 2. Now create ITEM tiers with REF_ANNOTATIONs (only if align_items=FALSE) (No change)#
  if (!align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        parent_tier_name <- NULL#
        for (item in level$items) {#
          parent_id <- parent_map[[as.character(item$id)]]#
          if (!is.null(parent_id) && !is.null(level_map[[parent_id]])) {#
            parent_tier_name <- level_map[[parent_id]]#
            break#
          }#
        }#
        tier_attrs <- list(TIER_ID = level$name)#
        if (!is.null(parent_tier_name)) {#
          tier_attrs$PARENT_REF <- parent_tier_name#
          parent_level_obj <- emu_data$levels[[which(sapply(emu_data$levels, function(l) l$name == parent_tier_name))]]#
          if (!is.null(parent_level_obj) && parent_level_obj$type %in% c("SEGMENT", "EVENT")) {#
              tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-subdivision"#
          } else {#
              tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
          }#
        } else {#
          tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
        }#
        tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
        prev_annotation_id <- NULL#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          parent_id <- parent_map[[item_id]]#
          parent_ann_id <- NULL#
          if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
            parent_ann_id <- annotation_map[[parent_id]]#
          }#
          if (tier_attrs$LINGUISTIC_TYPE_REF %in% c("symbolic-subdivision", "symbolic-association") && !is.null(parent_ann_id)) {#
            annotation <- xml_add_child(tier, "ANNOTATION")#
            annot_value <- ""#
            if (!is.null(item$labels) && length(item$labels) > 0) {#
              label_values <- sapply(item$labels, function(l) l$value)#
              annot_value <- paste(label_values, collapse = "; ")#
            }#
            ann_id <- paste0("a", item_id)#
            ref_attrs <- list(#
              ANNOTATION_ID = ann_id,#
              ANNOTATION_REF = parent_ann_id#
            )#
            if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
              ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
            }#
            ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
            xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
            annotation_map[[item_id]] <- ann_id#
            prev_annotation_id <- ann_id#
          } #
          else if (is.null(parent_tier_name) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-association") {#
            if (length(annotation_map) > 0) {#
              first_ann_id <- annotation_map[[1]] #
              annotation <- xml_add_child(tier, "ANNOTATION")#
              annot_value <- ""#
              if (!is.null(item$labels) && length(item$labels) > 0) {#
                label_values <- sapply(item$labels, function(l) l$value)#
                annot_value <- paste(label_values, collapse = "; ")#
              }#
              ann_id <- paste0("a", item_id)#
              ref_attrs <- list(#
                ANNOTATION_ID = ann_id,#
                ANNOTATION_REF = first_ann_id #
              )#
              ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
              xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
              annotation_map[[item_id]] <- ann_id#
            }#
          }#
        }#
      }#
    }#
  }#
  # Add linguistic types and constraints (No change)#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf",align_items=TRUE)
library(Rcpp)
Rcpp::sourceCpp("~/Downloads/rmsana_rcpp.cpp")
ls()
##' Short-term Root Mean Square amplitude of signals (Rcpp-optimized)#
##'#
##' @description The RMS amplitude is computed for each window of `windowSize`#
##'   length in the input signals files listed in `listOfFiles`. Per default, the#
##'   RMS values are expressed in decibel (dB) so that they correspond to the#
##'   short-term power of the signal. Input signals not in a file format natively#
##'   supported will be converted before the autocorrelation functions are#
##'   computed. The conversion process will display warnings about input files#
##'   that are not in known losslessly encoded formats.#
##'#
##'   The results will be will be written to an SSFF formated file with the base#
##'   name of the input file and extension *.rms* in a track *RMS*.#
##'#
##' @details The function is a re-write of the [wrassp::rmsana] function, but#
##'   with media pre-conversion, better checking of preconditions such as the#
##'   input file existence, structured logging, and the use of a more modern#
##'   framework for user feedback. This version includes Rcpp optimizations#
##'   for improved performance on large batches of files.#
##'#
##' @note#
##' This function is not considered computationally expensive enough to require caching of #
##' results if applied to many signals. However, if the number of signals it will be applied to #
##' is *very* large, then caching of results may be warranted.#
##' #
##' @return The number of successfully written files (if `toFile=TRUE`), or a vector of `AsspDataObj` objects (if `toFile=FALSE`).#
##' #
##' @inheritParams acfana#
##' @param linear Should linear RMS values be computed? The default (`FALSE`)#
##'   means that the output will be on a logarithmic decibel scale (dB).#
##' @useDynLib superassp, .registration = TRUE#
##' @importFrom Rcpp sourceCpp#
##' @export#
##'#
rmsana <- function(listOfFiles = NULL,#
                   beginTime = 0.0,#
                   centerTime = FALSE,#
                   endTime = 0.0,#
                   windowShift = 5.0,#
                   windowSize = 20.0,#
                   effectiveLength = TRUE,#
                   linear = FALSE,#
                   window = 'HAMMING',#
                   toFile = TRUE,#
                   explicitExt = "rms",#
                   outputDirectory = NULL,#
                   assertLossless = NULL,#
                   logToFile = FALSE,#
                   convertOverwrites = FALSE,#
                   keepConverted = FALSE,#
                   verbose = TRUE) {#
  ## Initial constants#
  explicitExt <- if(is.null(explicitExt)) "rms" else explicitExt#
  newTracknames <- "RMS[dB]"#
  nativeFiletypes <- c("wav", "au", "kay", "nist", "nsp")#
  currCall <- rlang::current_call()#
  funName <- rlang::call_name(currCall)#
  preferedFiletype <- nativeFiletypes[1L]#
  knownLossless <- c(assertLossless, knownLossless())#
  # Normalize and validate inputs#
  beginTime <- if(is.null(beginTime)) 0.0 else beginTime#
  endTime <- if(is.null(endTime)) 0.0 else endTime#
  n_files <- length(listOfFiles)#
  # Validate time parameter lengths#
  if(length(beginTime) > 1L && length(beginTime) != n_files) {#
    cli::cli_abort("The {.par beginTime} must be length 1 or match {.par listOfFiles} length.")#
  }#
  if(length(endTime) > 1L && length(endTime) != n_files) {#
    cli::cli_abort("The {.par endTime} must be length 1 or match {.par listOfFiles} length.")#
  }#
  # Use Rcpp for efficient time parameter recycling#
  beginTime <- fast_recycle_times(beginTime, n_files)#
  endTime <- fast_recycle_times(endTime, n_files)#
  #### Setup logging #####
  makeOutputDirectory(outputDirectory, logToFile, funName)#
  #### Input file conversion (Rcpp-optimized) #####
  listOfFiles_toClear <- convertInputMediaFiles_rcpp(#
    listOfFiles, beginTime, endTime, windowShift, #
    nativeFiletypes, preferedFiletype, knownLossless, #
    funName, keepConverted, verbose#
  )#
  listOfFilesDF <- listOfFiles_toClear[[1]]#
  toClear <- listOfFiles_toClear[[2]]#
  # Verify all files are in native format (using Rcpp)#
  file_exts <- fast_file_ext(listOfFilesDF$dsp_input)#
  if(!all(fast_is_native(file_exts, nativeFiletypes))) {#
    cli::cli_abort("File conversion failed - non-native formats remain")#
  }#
  #### Application of DSP C function  #####
  if(verbose) {#
    cli::cli_inform("Applying {.fun {funName}} to {cli::no(n_files)} recording{?s}")#
  }#
  # Optimized C function caller#
  applyC_DSPfunction <- function(x, bt, et) {#
    .External("performAssp", x, #
              fname = "rmsana", #
              beginTime = bt, #
              centerTime = centerTime, #
              endTime = et, #
              windowShift = windowShift, #
              windowSize = windowSize, #
              effectiveLength = effectiveLength, #
              linear = linear, #
              window = window, #
              toFile = toFile, #
              explicitExt = explicitExt, #
              progressBar = NULL, #
              outputDirectory = outputDirectory,#
              PACKAGE = "superassp")#
  }#
  # Process files with vectorized approach#
  externalRes <- Map(#
    applyC_DSPfunction,#
    listOfFilesDF$dsp_input,#
    listOfFilesDF$beginTime,#
    listOfFilesDF$endTime#
  )#
  # Use Rcpp for fast track renaming#
  if(!is.null(newTracknames)) {#
    n_tracks <- length(names(externalRes[[1]]))#
    if(n_tracks != length(newTracknames)) {#
      cli::cli_abort(c(#
        "Wrong number of track names supplied:",#
        "i" = "Track{?s} named: {.field {names(externalRes[[1]])}}"#
      ))#
    }#
    externalRes <- fast_rename_tracks(externalRes, newTracknames)#
  }#
  # Write output files if requested#
  if(toFile) {#
    # Efficient batch writing#
    for(i in seq_along(externalRes)) {#
      writeSSFFOutputFile(#
        externalRes[[i]], #
        listOfFilesDF$audio[i],#
        explicitExt, #
        outputDirectory, #
        verbose#
      )#
    }#
  }#
  # Simplify output for single file#
  if(n_files == 1L) externalRes <- externalRes[[1]]#
  #### Cleanup #####
  cleanupConvertedInputMediaFiles(toClear, keepConverted, verbose)#
  return(externalRes)#
}#
#
##' Convert input media files (Rcpp-optimized version)#
##' @keywords internal#
convertInputMediaFiles_rcpp <- function(listOfFiles, beginTime, endTime, #
                                       windowShift, nativeFiletypes, #
                                       preferedFiletype, knownLossless, #
                                       funName, keepConverted, verbose) {#
  if(length(listOfFiles) < 1) return(list(data.frame(), character()))#
  # Strip file:// protocol using Rcpp#
  listOfFiles <- fast_strip_file_protocol(listOfFiles)#
  listOfFiles <- normalizePath(path.expand(listOfFiles))#
  # Check file existence using Rcpp#
  files_exist <- fast_file_exists(listOfFiles)#
  if(!all(files_exist)) {#
    missing <- listOfFiles[!files_exist]#
    cli::cli_abort(c(#
      "Some files do not exist:",#
      "x" = "{.file {basename(missing)}}"#
    ))#
  }#
  # Validate time windows using Rcpp#
  fast_validate_times(beginTime, endTime, basename(listOfFiles))#
  # Use Rcpp for fast extension extraction and checking#
  audio_ext <- fast_file_ext(listOfFiles)#
  is_native <- fast_is_native(audio_ext, nativeFiletypes)#
  is_lossless <- fast_is_lossless(audio_ext, knownLossless)#
  # Determine which files need conversion#
  needs_conversion <- !is_native#
  needs_timewindow <- needs_conversion & (endTime != beginTime)#
  # Generate output paths using Rcpp#
  output_paths <- fast_generate_output_paths(#
    listOfFiles, #
    preferedFiletype,#
    is_native,#
    needs_timewindow#
  )#
  # Build processing dataframe#
  listOfFilesDF <- data.frame(#
    audio = listOfFiles,#
    audio_ext = audio_ext,#
    output_ext = ifelse(is_native, audio_ext, preferedFiletype),#
    lossless = is_lossless,#
    convert_file = needs_conversion,#
    convert_timewindow = needs_timewindow,#
    dsp_input = output_paths,#
    beginTime = ifelse(needs_timewindow, 0.0, beginTime),#
    endTime = ifelse(needs_timewindow, 0.0, endTime),#
    stringsAsFactors = FALSE#
  )#
  # Warn about lossless formats#
  if(any(!is_lossless)) {#
    cli::cli_warn(c(#
      "w" = "Found {sum(!is_lossless)} recording{?s} in non-optimal format{?s}",#
      "i" = "Use native lossless formats when possible: {.val {intersect(nativeFiletypes, knownLossless)}}"#
    ))#
  }#
  # Use Rcpp to build conversion list efficiently#
  if(any(needs_conversion | needs_timewindow)) {#
    conversion_list <- fast_build_conversion_list(#
      listOfFiles,#
      output_paths,#
      needs_conversion,#
      needs_timewindow#
    )#
    if(length(conversion_list$audio) > 0) {#
      cli::cli_inform(c(#
        "Converting {length(conversion_list$audio)} file{?s}",#
        "i" = "Use native formats to avoid conversion: {.val {nativeFiletypes}}"#
      ))#
      # Get file durations for time calculations#
      durations <- vapply(#
        conversion_list$audio,#
        function(f) av::av_media_info(f)$duration,#
        numeric(1)#
      )#
      # Calculate conversion times using Rcpp#
      indices <- conversion_list$indices + 1  # R uses 1-indexing#
      time_calcs <- fast_calculate_conversion_times(#
        beginTime[indices],#
        endTime[indices],#
        durations,#
        windowShift#
      )#
      # Perform conversions#
      toConvert <- data.frame(#
        audio = conversion_list$audio,#
        output = conversion_list$output,#
        start_time = time_calcs$start_time,#
        total_time = time_calcs$total_time,#
        stringsAsFactors = FALSE#
      )#
      purrr::pwalk(#
        toConvert,#
        av::av_audio_convert,#
        verbose = FALSE,#
        channels = 1,#
        format = NULL#
      )#
      # Verify conversions#
      if(!all(file.exists(toConvert$output))) {#
        cli::cli_abort("Some file conversions failed")#
      }#
      return(list(listOfFilesDF, toConvert$output))#
    }#
  }#
  return(list(listOfFilesDF, character()))#
}#
#
# Function attributes#
