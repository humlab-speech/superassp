#
          for (child_id in child_ids) {#
            child_ann_id <- annotation_map[[as.character(child_id)]]#
            if (!is.null(child_ann_id)) {#
              # Extract start and end times from child annotations#
              # This assumes child annotations are ALIGNABLE_ANNOTATIONs#
              child_annot <- xml_find_all(doc, paste0("//ANNOTATION[@ANNOTATION_ID='", child_ann_id, "']/ALIGNABLE_ANNOTATION"))#
              if (length(child_annot) > 0) {#
                start_ts <- xml_attr(child_annot[[1]], "TIME_SLOT_REF1")#
                end_ts <- xml_attr(child_annot[[1]], "TIME_SLOT_REF2")#
                start_time <- as.numeric(substr(start_ts, 3, nchar(start_ts)))#
                end_time <- as.numeric(substr(end_ts, 3, nchar(end_ts)))#
                child_start_times <- c(child_start_times, start_time)#
                child_end_times <- c(child_end_times, end_time)#
              }#
            }#
          }#
#
          if (length(child_start_times) > 0 && length(child_end_times) > 0) {#
            min_start <- min(child_start_times)#
            max_end <- max(child_end_times)#
#
            # Create ALIGNABLE_ANNOTATION for ITEM#
            annotation <- xml_add_child(tier, "ANNOTATION")#
            ann_id <- paste0("a", item_id)#
            alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                      ANNOTATION_ID = ann_id,#
                                      TIME_SLOT_REF1 = time_slot_map[[as.character(min_start)]],#
                                      TIME_SLOT_REF2 = time_slot_map[[as.character(max_end)]])#
#
            # Get annotation value#
            annot_value <- ""#
            if (!is.null(item$labels) && length(item$labels) > 0) {#
              label_values <- sapply(item$labels, function(l) l$value)#
              annot_value <- paste(label_values, collapse = "; ")#
            }#
            xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
            annotation_map[[item_id]] <- ann_id#
            prev_annotation_id <- ann_id#
          }#
        }#
      } else {#
        # Original logic for REF_ANNOTATION#
        parent_ann_id <- NULL#
        if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
          parent_ann_id <- annotation_map[[parent_id]]#
        } else {#
          if (length(annotation_map) > 0) {#
            parent_ann_id <- annotation_map[[1]]#
          }#
        }#
#
        if (!is.null(parent_ann_id)) {#
          annotation <- xml_add_child(tier, "ANNOTATION")#
#
          annot_value <- ""#
          if (!is.null(item$labels) && length(item$labels) > 0) {#
            label_values <- sapply(item$labels, function(l) l$value)#
            annot_value <- paste(label_values, collapse = "; ")#
          }#
#
          ann_id <- paste0("a", item_id)#
#
          ref_attrs <- list(#
            ANNOTATION_ID = ann_id,#
            ANNOTATION_REF = parent_ann_id#
          )#
#
          if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
            ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
          }#
#
          ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
          xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
#
          annotation_map[[item_id]] <- ann_id#
          prev_annotation_id <- ann_id#
        }#
      }#
    }#
  }#
}#
  # Add linguistic types#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  # Add constraints#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf")
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf",align_items = TRUE)
library(jsonlite)#
library(xml2)#
#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL,#
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL, #
                               align_items = FALSE) { # New parameter#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  sample_rate <- emu_data$sampleRate # Store sample rate for convenience#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # 1. Create document root and header#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z"),#
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file)) {#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # 2. Build link maps and item details map#
  parent_map <- list()#
  children_map <- list()#
  item_details_map <- list()#
  # Pre-map all items and their level types for fast lookup#
  for (level in emu_data$levels) {#
    for (item in level$items) {#
      item_details_map[[as.character(item$id)]] <- list(#
        level_name = level$name,#
        level_type = level$type,#
        item_data = item#
      )#
    }#
  }#
  # Build link maps (ID to ID)#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id # Child ID -> Parent ID#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id) # Parent ID -> List of Child IDs#
    }#
  }#
  # 3. Recursive Helper Function (for align_items = TRUE)#
  # This function traverses the dominance hierarchy to find the bounding SEGMENT/EVENT times.#
  find_terminal_times <- function(parent_id, children_map, item_details_map, sample_rate) {#
    times <- list(start = numeric(), end = numeric())#
    children_ids <- children_map[[as.character(parent_id)]]#
    if (is.null(children_ids)) return(times)#
    for (child_id_str in children_ids) {#
      child_details <- item_details_map[[child_id_str]]#
      if (!is.null(child_details)) {#
        level_type <- child_details$level_type#
        item <- child_details$item_data#
        if (level_type %in% c("SEGMENT", "EVENT")) {#
          # Base case: Time-aligned annotation found#
          if (level_type == "SEGMENT") {#
            start_ms <- round((item$sampleStart / sample_rate) * 1000)#
            end_ms <- round(((item$sampleStart + item$sampleDur) / sample_rate) * 1000)#
          } else if (level_type == "EVENT") {#
            # EVENTs are points, start = end = point#
            start_ms <- round((item$samplePoint / sample_rate) * 1000)#
            end_ms <- start_ms #
          }#
          times$start <- c(times$start, start_ms)#
          times$end <- c(times$end, end_ms)#
        } else if (level_type == "ITEM") {#
          # Recursive step: Traverse deeper#
          sub_times <- find_terminal_times(as.numeric(child_id_str), children_map, item_details_map, sample_rate)#
          times$start <- c(times$start, sub_times$start)#
          times$end <- c(times$end, sub_times$end)#
        }#
      }#
    }#
    return(times)#
  }#
  # 4. Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points from SEGMENT/EVENTs#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / sample_rate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / sample_rate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / sample_rate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  # If align_items is TRUE, also calculate and include min/max times for all ITEMs#
  if (align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          terminal_times <- find_terminal_times(as.numeric(item_id), children_map, item_details_map, sample_rate)#
          if (length(terminal_times$start) > 0) {#
            all_time_points <- c(all_time_points, min(terminal_times$start), max(terminal_times$end))#
          }#
        }#
      }#
    }#
  }#
  # Create TIME_SLOTs#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # 5. Create TIERs and ANNOTATIONs#
  annotation_map <- list()#
  tiers_container <- list()#
  # 5a. Process all tiers#
  for (level in emu_data$levels) {#
    tier_id <- level$name#
    # Determine the appropriate LINGUISTIC_TYPE_REF for the tier#
    linguistic_type_ref <- switch(level$type,#
                                  "SEGMENT" = "time-aligned",#
                                  "EVENT" = "time-aligned",#
                                  "ITEM" = if (align_items) "time-aligned-item" else "symbolic-association",#
                                  NULL)#
    # Find PARENT_REF (non-trivial: we use the first dominating tier's name)#
    parent_tier_name <- NULL#
    for (item in level$items) {#
      parent_id <- parent_map[[as.character(item$id)]]#
      if (!is.null(parent_id)) {#
        parent_details <- item_details_map[[parent_id]]#
        if (!is.null(parent_details)) {#
          parent_tier_name <- parent_details$level_name#
          break#
        }#
      }#
    }#
    # Create TIER element#
    tier_el <- xml_add_child(doc, "TIER",#
                             TIER_ID = tier_id,#
                             LINGUISTIC_TYPE_REF = linguistic_type_ref,#
                             PARENT_REF = parent_tier_name)#
    tiers_container[[tier_id]] <- tier_el#
    # 5b. Process annotations within the tier#
    for (item in level$items) {#
      item_id <- as.character(item$id)#
      # Assume the first label value is the annotation text (ELAN only supports one value per annotation)#
      annotation_value <- item$labels[[1]]$value#
      a_id <- paste0("a", item_id)#
      annotation_el <- xml_add_child(tier_el, "ANNOTATION")#
      if (level$type %in% c("SEGMENT", "EVENT") || (level$type == "ITEM" && align_items)) {#
        # Create ALIGNABLE_ANNOTATION#
        if (level$type %in% c("SEGMENT", "EVENT")) {#
          # SEGMENT/EVENT time calculation#
          if (level$type == "SEGMENT") {#
            start_ms <- round((item$sampleStart / sample_rate) * 1000)#
            end_ms <- round(((item$sampleStart + item$sampleDur) / sample_rate) * 1000)#
          } else { # EVENT#
            start_ms <- round((item$samplePoint / sample_rate) * 1000)#
            end_ms <- start_ms#
          }#
        } else {#
          # ITEM (Time calculation based on children)#
          terminal_times <- find_terminal_times(as.numeric(item_id), children_map, item_details_map, sample_rate)#
          if (length(terminal_times$start) == 0) {#
            # Skip ITEM if it's supposed to be time-aligned but has no time-aligned children#
            message(paste("Skipping ITEM:", tier_id, item_id, "as it has no time-aligned children."))#
            next#
          }#
          start_ms <- min(terminal_times$start)#
          end_ms <- max(terminal_times$end)#
        }#
        ts1_id <- time_slot_map[[as.character(start_ms)]]#
        ts2_id <- time_slot_map[[as.character(end_ms)]]#
        alignable_el <- xml_add_child(annotation_el, "ALIGNABLE_ANNOTATION",#
                                      ANNOTATION_ID = a_id,#
                                      TIME_SLOT_REF1 = ts1_id,#
                                      TIME_SLOT_REF2 = ts2_id)#
        xml_add_child(alignable_el, "ANNOTATION_VALUE", .value = annotation_value)#
      } else if (level$type == "ITEM" && !align_items) {#
        # Create REF_ANNOTATION (Symbolic Association/Subdivision)#
        parent_item_id <- parent_map[[item_id]]#
        if (is.null(parent_item_id)) {#
          message(paste("Skipping ITEM:", tier_id, item_id, "as it is symbolic and has no parent annotation."))#
          next#
        }#
        parent_annotation_id <- annotation_map[[parent_item_id]]#
        if (is.null(parent_annotation_id)) {#
          message(paste("Skipping ITEM:", tier_id, item_id, "as parent annotation was not created."))#
          next#
        }#
        ref_el <- xml_add_child(annotation_el, "REF_ANNOTATION",#
                                ANNOTATION_ID = a_id,#
                                ANNOTATION_REF = parent_annotation_id)#
        xml_add_child(ref_el, "ANNOTATION_VALUE", .value = annotation_value)#
      }#
      annotation_map[[item_id]] <- a_id#
    }#
  }#
  # 6. Add LINGUISTIC_TYPEs#
  # Base time-aligned type (for SEGMENT/EVENT)#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "time-aligned",#
                TIME_ALIGNABLE = "true")#
  # New time-aligned type for ITEMs (when align_items=TRUE)#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "time-aligned-item",#
                TIME_ALIGNABLE = "true")#
  # Symbolic types (default for ITEMs when align_items=FALSE)#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association")#
  # 7. Add constraints#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations referring to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  # 8. Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf",align_items = TRUE)
library(jsonlite)#
library(xml2)#
#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL) {#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create document#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z"),#
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file)) {#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Build link maps#
  parent_map <- list()#
  children_map <- list()#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Store annotation IDs and level info#
  annotation_map <- list()#
  level_map <- list()#
  # Map items to their levels#
  for (level in emu_data$levels) {#
    for (item in level$items) {#
      level_map[[as.character(item$id)]] <- level$name#
    }#
  }#
  # First, create all tiers with time-aligned annotations#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      # Create tier#
      tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = "default-lt")#
      for (item in level$items) {#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          annot_value <- item$labels[[1]]$value#
        }#
        ann_id <- paste0("a", item$id)#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = ann_id,#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
        } else {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = ann_id,#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(point_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(point_ms)]])#
        }#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        annotation_map[[as.character(item$id)]] <- ann_id#
      }#
    }#
  }#
  # Now create ITEM tiers with REF_ANNOTATIONs#
  for (level in emu_data$levels) {#
    if (level$type == "ITEM") {#
      # Find a suitable parent tier#
      parent_tier <- NULL#
      for (item in level$items) {#
        parent_id <- parent_map[[as.character(item$id)]]#
        if (!is.null(parent_id) && !is.null(level_map[[parent_id]])) {#
          parent_tier <- level_map[[parent_id]]#
          break#
        }#
      }#
      # Create tier with parent reference if found#
      tier_attrs <- list(TIER_ID = level$name)#
      if (!is.null(parent_tier)) {#
        tier_attrs$PARENT_REF <- parent_tier#
        tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-subdivision"#
      } else {#
        # Find any time-aligned annotation to reference#
        for (item in level$items) {#
          parent_id <- parent_map[[as.character(item$id)]]#
          if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
            tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
            break#
          }#
        }#
        if (is.null(tier_attrs$LINGUISTIC_TYPE_REF)) {#
          tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
        }#
      }#
      tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
      # Add annotations#
      prev_annotation_id <- NULL#
      for (item in level$items) {#
        item_id <- as.character(item$id)#
        parent_id <- parent_map[[item_id]]#
        # Find a valid parent annotation#
        parent_ann_id <- NULL#
        if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
          parent_ann_id <- annotation_map[[parent_id]]#
        } else {#
          # Try to find any annotation to reference#
          # Use first available annotation from time-aligned tiers#
          if (length(annotation_map) > 0) {#
            parent_ann_id <- annotation_map[[1]]#
          }#
        }#
        if (!is.null(parent_ann_id)) {#
          annotation <- xml_add_child(tier, "ANNOTATION")#
          # Get all label values#
          annot_value <- ""#
          if (!is.null(item$labels) && length(item$labels) > 0) {#
            label_values <- sapply(item$labels, function(l) l$value)#
            annot_value <- paste(label_values, collapse = "; ")#
          }#
          ann_id <- paste0("a", item_id)#
          ref_attrs <- list(#
            ANNOTATION_ID = ann_id,#
            ANNOTATION_REF = parent_ann_id#
          )#
          # Add previous annotation for chaining if using subdivision#
          if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
            ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
          }#
          ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
          xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
          annotation_map[[item_id]] <- ann_id#
          prev_annotation_id <- ann_id#
        }#
      }#
    }#
  }#
  # Add linguistic types#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  # Add constraints#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf",align_items = TRUE)
library(jsonlite)#
library(xml2)#
#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL) {#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create document#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z"),#
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file)) {#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Build link maps#
  parent_map <- list()#
  children_map <- list()#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Store annotation IDs and level info#
  annotation_map <- list()#
  level_map <- list()#
  # Map items to their levels#
  for (level in emu_data$levels) {#
    for (item in level$items) {#
      level_map[[as.character(item$id)]] <- level$name#
    }#
  }#
  # First, create all tiers with time-aligned annotations#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      # Create tier#
      tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = "default-lt")#
      for (item in level$items) {#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          annot_value <- item$labels[[1]]$value#
        }#
        ann_id <- paste0("a", item$id)#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = ann_id,#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
        } else {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = ann_id,#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(point_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(point_ms)]])#
        }#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        annotation_map[[as.character(item$id)]] <- ann_id#
      }#
    }#
  }#
  # Now create ITEM tiers with REF_ANNOTATIONs#
  for (level in emu_data$levels) {#
    if (level$type == "ITEM") {#
      # Find a suitable parent tier#
      parent_tier <- NULL#
      for (item in level$items) {#
        parent_id <- parent_map[[as.character(item$id)]]#
        if (!is.null(parent_id) && !is.null(level_map[[parent_id]])) {#
          parent_tier <- level_map[[parent_id]]#
          break#
        }#
      }#
      # Create tier with parent reference if found#
      tier_attrs <- list(TIER_ID = level$name)#
      if (!is.null(parent_tier)) {#
        tier_attrs$PARENT_REF <- parent_tier#
        tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-subdivision"#
      } else {#
        # Find any time-aligned annotation to reference#
        for (item in level$items) {#
          parent_id <- parent_map[[as.character(item$id)]]#
          if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
            tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
            break#
          }#
        }#
        if (is.null(tier_attrs$LINGUISTIC_TYPE_REF)) {#
          tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
        }#
      }#
      tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
      # Add annotations#
      prev_annotation_id <- NULL#
      for (item in level$items) {#
        item_id <- as.character(item$id)#
        parent_id <- parent_map[[item_id]]#
        # Find a valid parent annotation#
        parent_ann_id <- NULL#
        if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
          parent_ann_id <- annotation_map[[parent_id]]#
        } else {#
          # Try to find any annotation to reference#
          # Use first available annotation from time-aligned tiers#
          if (length(annotation_map) > 0) {#
            parent_ann_id <- annotation_map[[1]]#
          }#
        }#
        if (!is.null(parent_ann_id)) {#
          annotation <- xml_add_child(tier, "ANNOTATION")#
          # Get all label values#
          annot_value <- ""#
          if (!is.null(item$labels) && length(item$labels) > 0) {#
            label_values <- sapply(item$labels, function(l) l$value)#
            annot_value <- paste(label_values, collapse = "; ")#
          }#
          ann_id <- paste0("a", item_id)#
          ref_attrs <- list(#
            ANNOTATION_ID = ann_id,#
            ANNOTATION_REF = parent_ann_id#
          )#
          # Add previous annotation for chaining if using subdivision#
          if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
            ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
          }#
          ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
          xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
          annotation_map[[item_id]] <- ann_id#
          prev_annotation_id <- ann_id#
        }#
      }#
    }#
  }#
  # Add linguistic types#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  # Add constraints#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf",align_items = TRUE)
library(jsonlite)#
library(xml2)#
#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL) {#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create document#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z"),#
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file)) {#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Build link maps#
  parent_map <- list()#
  children_map <- list()#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Store annotation IDs and level info#
  annotation_map <- list()#
  level_map <- list()#
  # Map items to their levels#
  for (level in emu_data$levels) {#
    for (item in level$items) {#
      level_map[[as.character(item$id)]] <- level$name#
    }#
  }#
  # First, create all tiers with time-aligned annotations#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      # Create tier#
      tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = "default-lt")#
      for (item in level$items) {#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          annot_value <- item$labels[[1]]$value#
        }#
        ann_id <- paste0("a", item$id)#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = ann_id,#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
        } else {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = ann_id,#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(point_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(point_ms)]])#
        }#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        annotation_map[[as.character(item$id)]] <- ann_id#
      }#
    }#
  }#
  # Now create ITEM tiers with REF_ANNOTATIONs#
  for (level in emu_data$levels) {#
    if (level$type == "ITEM") {#
      # Find a suitable parent tier#
      parent_tier <- NULL#
      for (item in level$items) {#
        parent_id <- parent_map[[as.character(item$id)]]#
        if (!is.null(parent_id) && !is.null(level_map[[parent_id]])) {#
          parent_tier <- level_map[[parent_id]]#
          break#
        }#
      }#
      # Create tier with parent reference if found#
      tier_attrs <- list(TIER_ID = level$name)#
      if (!is.null(parent_tier)) {#
        tier_attrs$PARENT_REF <- parent_tier#
        tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-subdivision"#
      } else {#
        # Find any time-aligned annotation to reference#
        for (item in level$items) {#
          parent_id <- parent_map[[as.character(item$id)]]#
          if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
            tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
            break#
          }#
        }#
        if (is.null(tier_attrs$LINGUISTIC_TYPE_REF)) {#
          tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
        }#
      }#
      tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
      # Add annotations#
      prev_annotation_id <- NULL#
      for (item in level$items) {#
        item_id <- as.character(item$id)#
        parent_id <- parent_map[[item_id]]#
        # Find a valid parent annotation#
        parent_ann_id <- NULL#
        if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
          parent_ann_id <- annotation_map[[parent_id]]#
        } else {#
          # Try to find any annotation to reference#
          # Use first available annotation from time-aligned tiers#
          if (length(annotation_map) > 0) {#
            parent_ann_id <- annotation_map[[1]]#
          }#
        }#
        if (!is.null(parent_ann_id)) {#
          annotation <- xml_add_child(tier, "ANNOTATION")#
          # Get all label values#
          annot_value <- ""#
          if (!is.null(item$labels) && length(item$labels) > 0) {#
            label_values <- sapply(item$labels, function(l) l$value)#
            annot_value <- paste(label_values, collapse = "; ")#
          }#
          ann_id <- paste0("a", item_id)#
          ref_attrs <- list(#
            ANNOTATION_ID = ann_id,#
            ANNOTATION_REF = parent_ann_id#
          )#
          # Add previous annotation for chaining if using subdivision#
          if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
            ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
          }#
          ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
          xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
          annotation_map[[item_id]] <- ann_id#
          prev_annotation_id <- ann_id#
        }#
      }#
    }#
  }#
  # Add linguistic types#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  # Add constraints#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf",align_items = TRUE)
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf")
library(jsonlite)#
library(xml2)#
#
# Helper function to recursively find the time range for an ITEM annotation#
get_item_time_range <- function(item_id, emu_data, children_map, time_points_map, level_map) {#
  # Base case: if item_id is a segment or event (i.e., time-aligned)#
  if (level_map[[item_id]] %in% c("SEGMENT", "EVENT")) {#
    level <- emu_data$levels[[which(sapply(emu_data$levels, function(l) l$name == level_map[[item_id]]))]]#
    item <- level$items[[which(sapply(level$items, function(i) as.character(i$id) == item_id))]]#
    if (level$type == "SEGMENT") {#
      start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
      end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
    } else { # EVENT#
      point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
      start_ms <- point_ms#
      end_ms <- point_ms#
    }#
    return(list(start = start_ms, end = end_ms))#
  }#
  # Recursive case: find children's time ranges#
  children_ids <- children_map[[item_id]]#
  if (is.null(children_ids)) {#
    return(NULL) # No time-aligned children#
  }#
  min_start <- Inf#
  max_end <- -Inf#
  for (child_id in children_ids) {#
    range <- get_item_time_range(child_id, emu_data, children_map, time_points_map, level_map)#
    if (!is.null(range)) {#
      min_start <- min(min_start, range$start)#
      max_end <- max(max_end, range$end)#
    }#
  }#
  if (is.infinite(min_start) || is.infinite(max_end)) {#
    return(NULL)#
  }#
  return(list(start = min_start, end = max_end))#
}#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL,#
                               align_items = FALSE) { # New argument#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create document#
  # FIX: Change DATE format to comply with XML Schema's 'dateTime' format (e.g., "YYYY-MM-DDThh:mm:ss+/-hh:mm")#
  date_string <- format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z")#
  date_string <- sub("([+-][0-9]{2})([0-9]{2})$", "\\1:\\2", date_string) # Reformat timezone for strict ISO 8601#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = date_string, # FIXED DATE FORMAT#
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file)) {#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Build link maps#
  parent_map <- list()#
  children_map <- list()#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Store level info (used in time calculation)#
  level_map <- list()#
  for (level in emu_data$levels) {#
    for (item in level$items) {#
      level_map[[as.character(item$id)]] <- level$name#
    }#
  }#
#
  # Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points from SEGMENT and EVENT levels#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  # Collect time points for ITEM tiers if align_items is TRUE#
  if (align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          time_range <- get_item_time_range(item_id, emu_data, children_map, time_slot_map, level_map)#
          if (!is.null(time_range)) {#
            all_time_points <- c(all_time_points, time_range$start, time_range$end)#
          }#
        }#
      }#
    }#
  }#
#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Store annotation IDs#
  annotation_map <- list()#
  # 1. Create all tiers with time-aligned annotations (SEGMENT, EVENT, and ITEM if align_items=TRUE)#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT") || (level$type == "ITEM" && align_items)) {#
      # Create tier#
      tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = "default-lt")#
      for (item in level$items) {#
        item_id <- as.character(item$id)#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        ann_id <- paste0("a", item_id)#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          # ITEM tiers may have multiple labels#
          label_values <- sapply(item$labels, function(l) l$value)#
          annot_value <- paste(label_values, collapse = "; ")#
        }#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          start_ms <- point_ms#
          end_ms <- point_ms#
        } else if (level$type == "ITEM" && align_items) {#
          time_range <- get_item_time_range(item_id, emu_data, children_map, time_slot_map, level_map)#
          if (is.null(time_range)) next # Skip if no time-aligned children found#
          start_ms <- time_range$start#
          end_ms <- time_range$end#
        } else {#
          next # Should not happen based on condition#
        }#
        alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                 ANNOTATION_ID = ann_id,#
                                 TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                 TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        annotation_map[[item_id]] <- ann_id#
      }#
    }#
  }#
  # 2. Now create ITEM tiers with REF_ANNOTATIONs (only if align_items=FALSE)#
  if (!align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        # Find a suitable parent tier#
        parent_tier_name <- NULL#
        for (item in level$items) {#
          parent_id <- parent_map[[as.character(item$id)]]#
          if (!is.null(parent_id) && !is.null(level_map[[parent_id]])) {#
            parent_tier_name <- level_map[[parent_id]]#
            break#
          }#
        }#
        # Create tier with parent reference if found#
        tier_attrs <- list(TIER_ID = level$name)#
        if (!is.null(parent_tier_name)) {#
          tier_attrs$PARENT_REF <- parent_tier_name#
          # Use symbolic-subdivision if the parent is time-aligned (SEGMENT/EVENT)#
          # Use symbolic-association if the parent is also an ITEM (or other non-time-aligned)#
          if (!is.null(parent_tier_name) && level_map[[parent_map[[as.character(level$items[[1]]$id)]]]] %in% c("SEGMENT", "EVENT")) {#
              tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-subdivision"#
          } else {#
              tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
          }#
        } else {#
          # FIX: If no parent is found, it must be a time-alignable type or no constraints.#
          # Default to 'default-lt' (time-alignable) or 'symbolic-association' (if intended to be a root symbolic tier)#
          # Given the Utterance error, setting it to 'default-lt' is the safer approach for an unlinked root tier.#
          tier_attrs$LINGUISTIC_TYPE_REF <- "default-lt"#
        }#
        tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
        # Add annotations#
        prev_annotation_id <- NULL#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          parent_id <- parent_map[[item_id]]#
          # Find a valid parent annotation ID#
          parent_ann_id <- NULL#
          if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
            parent_ann_id <- annotation_map[[parent_id]]#
          }#
          if (!is.null(parent_ann_id)) {#
            annotation <- xml_add_child(tier, "ANNOTATION")#
            # Get all label values#
            annot_value <- ""#
            if (!is.null(item$labels) && length(item$labels) > 0) {#
              label_values <- sapply(item$labels, function(l) l$value)#
              annot_value <- paste(label_values, collapse = "; ")#
            }#
            ann_id <- paste0("a", item_id)#
            ref_attrs <- list(#
              ANNOTATION_ID = ann_id,#
              ANNOTATION_REF = parent_ann_id#
            )#
            # Add previous annotation for chaining if using subdivision#
            if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
              ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
            }#
            ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
            xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
            annotation_map[[item_id]] <- ann_id#
            prev_annotation_id <- ann_id#
          }#
        }#
      }#
    }#
  }#
  # Add linguistic types (ensuring no redundant types are added)#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  # Add constraints#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf")
# (The helper function get_item_time_range and the initial parts of #
# convert_emu_to_eaf remain the same as in the previous response)#
#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL,#
                               align_items = FALSE) { #
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create document#
  date_string <- format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z")#
  date_string <- sub("([+-][0-9]{2})([0-9]{2})$", "\\1:\\2", date_string) # Reformat timezone for strict ISO 8601#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = date_string, #
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file)) {#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Build link maps#
  parent_map <- list()#
  children_map <- list()#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Store level info #
  level_map <- list()#
  for (level in emu_data$levels) {#
    for (item in level$items) {#
      level_map[[as.character(item$id)]] <- level$name#
    }#
  }#
#
  # Create TIME_ORDER (logic remains the same)#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points (SEGMENT/EVENT + ITEM if align_items=TRUE)#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  if (align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          time_range <- get_item_time_range(item_id, emu_data, children_map, time_slot_map, level_map)#
          if (!is.null(time_range)) {#
            all_time_points <- c(all_time_points, time_range$start, time_range$end)#
          }#
        }#
      }#
    }#
  }#
#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Store annotation IDs#
  annotation_map <- list()#
  # 1. Create all tiers with time-aligned annotations (SEGMENT, EVENT, and ITEM if align_items=TRUE)#
  # This section remains unchanged and correctly builds the time-aligned annotations and their IDs.#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT") || (level$type == "ITEM" && align_items)) {#
      # Create tier#
      tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = "default-lt")#
      for (item in level$items) {#
        item_id <- as.character(item$id)#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        ann_id <- paste0("a", item_id)#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          label_values <- sapply(item$labels, function(l) l$value)#
          annot_value <- paste(label_values, collapse = "; ")#
        }#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          start_ms <- point_ms#
          end_ms <- point_ms#
        } else if (level$type == "ITEM" && align_items) {#
          time_range <- get_item_time_range(item_id, emu_data, children_map, time_slot_map, level_map)#
          if (is.null(time_range)) next#
          start_ms <- time_range$start#
          end_ms <- time_range$end#
        } else {#
          next#
        }#
        alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                 ANNOTATION_ID = ann_id,#
                                 TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                 TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        annotation_map[[item_id]] <- ann_id#
      }#
    }#
  }#
  # 2. Now create ITEM tiers with REF_ANNOTATIONs (only if align_items=FALSE)#
  if (!align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        # Find a suitable parent tier name (if any item in the tier has a parent)#
        parent_tier_name <- NULL#
        first_item_parent_id <- NULL#
        for (item in level$items) {#
          parent_id <- parent_map[[as.character(item$id)]]#
          if (!is.null(parent_id) && !is.null(level_map[[parent_id]])) {#
            parent_tier_name <- level_map[[parent_id]]#
            first_item_parent_id <- parent_id#
            break#
          }#
        }#
        # Determine the linguistic type and parent reference for the TIER itself#
        tier_attrs <- list(TIER_ID = level$name)#
        if (!is.null(parent_tier_name)) {#
          tier_attrs$PARENT_REF <- parent_tier_name#
          # Check if the parent tier is time-aligned (SEGMENT/EVENT)#
          is_parent_time_aligned <- FALSE#
          # We need to find the level type of the parent#
          parent_level_obj <- emu_data$levels[[which(sapply(emu_data$levels, function(l) l$name == parent_tier_name))]]#
          if (!is.null(parent_level_obj) && parent_level_obj$type %in% c("SEGMENT", "EVENT")) {#
            is_parent_time_aligned <- TRUE#
          }#
          if (is_parent_time_aligned) {#
              tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-subdivision"#
          } else {#
              tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
          }#
        } else {#
          # If no parent is found, default to 'default-lt' to avoid Symbolic Association constraint error#
          tier_attrs$LINGUISTIC_TYPE_REF <- "default-lt"#
        }#
        tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
        # Add annotations#
        prev_annotation_id <- NULL#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          parent_id <- parent_map[[item_id]]#
          # Find a valid parent annotation ID in the map#
          parent_ann_id <- NULL#
          if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
            parent_ann_id <- annotation_map[[parent_id]]#
          }#
          # --- FIXED LOGIC: ONLY CREATE REF_ANNOTATION IF A VALID PARENT ANNOTATION IS FOUND ---#
          if (!is.null(parent_ann_id)) {#
            # If the tier ended up as 'default-lt', we must create an ALIGNABLE_ANNOTATION, #
            # but since EMU ITEM annotations are non-time-aligned, we should skip this #
            # if we can't link it symbolically. The best fix is to only write the annotation #
            # if the tier's LT is symbolic.#
            if (tier_attrs$LINGUISTIC_TYPE_REF %in% c("symbolic-subdivision", "symbolic-association")) {#
              annotation <- xml_add_child(tier, "ANNOTATION")#
              # Get all label values#
              annot_value <- ""#
              if (!is.null(item$labels) && length(item$labels) > 0) {#
                label_values <- sapply(item$labels, function(l) l$value)#
                annot_value <- paste(label_values, collapse = "; ")#
              }#
              ann_id <- paste0("a", item_id)#
              ref_attrs <- list(#
                ANNOTATION_ID = ann_id,#
                ANNOTATION_REF = parent_ann_id#
              )#
              # Add previous annotation for chaining if using subdivision#
              if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
                ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
              }#
              ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
              xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
              annotation_map[[item_id]] <- ann_id#
              prev_annotation_id <- ann_id#
            }#
          }#
          # --- END FIXED LOGIC ---#
        }#
      }#
    }#
  }#
  # Add linguistic types and constraints (unchanged)#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf")
library(jsonlite)#
library(xml2)#
#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL) {#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create document#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z"),#
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file)) {#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Build link maps#
  parent_map <- list()#
  children_map <- list()#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Store annotation IDs and level info#
  annotation_map <- list()#
  level_map <- list()#
  # Map items to their levels#
  for (level in emu_data$levels) {#
    for (item in level$items) {#
      level_map[[as.character(item$id)]] <- level$name#
    }#
  }#
  # First, create all tiers with time-aligned annotations#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      # Create tier#
      tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = "default-lt")#
      for (item in level$items) {#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          annot_value <- item$labels[[1]]$value#
        }#
        ann_id <- paste0("a", item$id)#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = ann_id,#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
        } else {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = ann_id,#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(point_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(point_ms)]])#
        }#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        annotation_map[[as.character(item$id)]] <- ann_id#
      }#
    }#
  }#
  # Now create ITEM tiers with REF_ANNOTATIONs#
  for (level in emu_data$levels) {#
    if (level$type == "ITEM") {#
      # Find a suitable parent tier#
      parent_tier <- NULL#
      for (item in level$items) {#
        parent_id <- parent_map[[as.character(item$id)]]#
        if (!is.null(parent_id) && !is.null(level_map[[parent_id]])) {#
          parent_tier <- level_map[[parent_id]]#
          break#
        }#
      }#
      # Create tier with parent reference if found#
      tier_attrs <- list(TIER_ID = level$name)#
      if (!is.null(parent_tier)) {#
        tier_attrs$PARENT_REF <- parent_tier#
        tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-subdivision"#
      } else {#
        # Find any time-aligned annotation to reference#
        for (item in level$items) {#
          parent_id <- parent_map[[as.character(item$id)]]#
          if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
            tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
            break#
          }#
        }#
        if (is.null(tier_attrs$LINGUISTIC_TYPE_REF)) {#
          tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
        }#
      }#
      tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
      # Add annotations#
      prev_annotation_id <- NULL#
      for (item in level$items) {#
        item_id <- as.character(item$id)#
        parent_id <- parent_map[[item_id]]#
        # Find a valid parent annotation#
        parent_ann_id <- NULL#
        if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
          parent_ann_id <- annotation_map[[parent_id]]#
        } else {#
          # Try to find any annotation to reference#
          # Use first available annotation from time-aligned tiers#
          if (length(annotation_map) > 0) {#
            parent_ann_id <- annotation_map[[1]]#
          }#
        }#
        if (!is.null(parent_ann_id)) {#
          annotation <- xml_add_child(tier, "ANNOTATION")#
          # Get all label values#
          annot_value <- ""#
          if (!is.null(item$labels) && length(item$labels) > 0) {#
            label_values <- sapply(item$labels, function(l) l$value)#
            annot_value <- paste(label_values, collapse = "; ")#
          }#
          ann_id <- paste0("a", item_id)#
          ref_attrs <- list(#
            ANNOTATION_ID = ann_id,#
            ANNOTATION_REF = parent_ann_id#
          )#
          # Add previous annotation for chaining if using subdivision#
          if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
            ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
          }#
          ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
          xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
          annotation_map[[item_id]] <- ann_id#
          prev_annotation_id <- ann_id#
        }#
      }#
    }#
  }#
  # Add linguistic types#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  # Add constraints#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf")
library(jsonlite)#
library(xml2)#
#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL) {#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create document#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z"),#
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file)) {#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Build link maps#
  parent_map <- list()#
  children_map <- list()#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Store annotation IDs and level info#
  annotation_map <- list()#
  level_map <- list()#
  # Map items to their levels#
  for (level in emu_data$levels) {#
    for (item in level$items) {#
      level_map[[as.character(item$id)]] <- level$name#
    }#
  }#
  # First, create all tiers with time-aligned annotations#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      # Create tier#
      tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = "default-lt")#
      for (item in level$items) {#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          annot_value <- item$labels[[1]]$value#
        }#
        ann_id <- paste0("a", item$id)#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = ann_id,#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
        } else {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                   ANNOTATION_ID = ann_id,#
                                   TIME_SLOT_REF1 = time_slot_map[[as.character(point_ms)]],#
                                   TIME_SLOT_REF2 = time_slot_map[[as.character(point_ms)]])#
        }#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        annotation_map[[as.character(item$id)]] <- ann_id#
      }#
    }#
  }#
  # Now create ITEM tiers with REF_ANNOTATIONs#
  for (level in emu_data$levels) {#
    if (level$type == "ITEM") {#
      # Find a suitable parent tier#
      parent_tier <- NULL#
      for (item in level$items) {#
        parent_id <- parent_map[[as.character(item$id)]]#
        if (!is.null(parent_id) && !is.null(level_map[[parent_id]])) {#
          parent_tier <- level_map[[parent_id]]#
          break#
        }#
      }#
      # Create tier with parent reference if found#
      tier_attrs <- list(TIER_ID = level$name)#
      if (!is.null(parent_tier)) {#
        tier_attrs$PARENT_REF <- parent_tier#
        tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-subdivision"#
      } else {#
        # Find any time-aligned annotation to reference#
        for (item in level$items) {#
          parent_id <- parent_map[[as.character(item$id)]]#
          if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
            tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
            break#
          }#
        }#
        if (is.null(tier_attrs$LINGUISTIC_TYPE_REF)) {#
          tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
        }#
      }#
      tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
      # Add annotations#
      prev_annotation_id <- NULL#
      for (item in level$items) {#
        item_id <- as.character(item$id)#
        parent_id <- parent_map[[item_id]]#
        # Find a valid parent annotation#
        parent_ann_id <- NULL#
        if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
          parent_ann_id <- annotation_map[[parent_id]]#
        } else {#
          # Try to find any annotation to reference#
          # Use first available annotation from time-aligned tiers#
          if (length(annotation_map) > 0) {#
            parent_ann_id <- annotation_map[[1]]#
          }#
        }#
        if (!is.null(parent_ann_id)) {#
          annotation <- xml_add_child(tier, "ANNOTATION")#
          # Get all label values#
          annot_value <- ""#
          if (!is.null(item$labels) && length(item$labels) > 0) {#
            label_values <- sapply(item$labels, function(l) l$value)#
            annot_value <- paste(label_values, collapse = "; ")#
          }#
          ann_id <- paste0("a", item_id)#
          ref_attrs <- list(#
            ANNOTATION_ID = ann_id,#
            ANNOTATION_REF = parent_ann_id#
          )#
          # Add previous annotation for chaining if using subdivision#
          if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
            ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
          }#
          ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
          xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
          annotation_map[[item_id]] <- ann_id#
          prev_annotation_id <- ann_id#
        }#
      }#
    }#
  }#
  # Add linguistic types#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  # Add constraints#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf")
library(jsonlite)#
library(xml2)#
#
# Helper function to recursively find the time range for an ITEM annotation#
get_item_time_range <- function(item_id, emu_data, children_map, time_points_map, level_map) {#
  # Base case: if item_id is a segment or event (i.e., time-aligned)#
  if (level_map[[item_id]] %in% c("SEGMENT", "EVENT")) {#
    level <- emu_data$levels[[which(sapply(emu_data$levels, function(l) l$name == level_map[[item_id]]))]]#
    item <- level$items[[which(sapply(level$items, function(i) as.character(i$id) == item_id))]]#
    if (level$type == "SEGMENT") {#
      start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
      end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
    } else { # EVENT#
      point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
      start_ms <- point_ms#
      end_ms <- point_ms#
    }#
    return(list(start = start_ms, end = end_ms))#
  }#
  # Recursive case: find children's time ranges#
  children_ids <- children_map[[item_id]]#
  if (is.null(children_ids)) {#
    return(NULL) # No time-aligned children#
  }#
  min_start <- Inf#
  max_end <- -Inf#
  for (child_id in children_ids) {#
    range <- get_item_time_range(child_id, emu_data, children_map, time_points_map, level_map)#
    if (!is.null(range)) {#
      min_start <- min(min_start, range$start)#
      max_end <- max(max_end, range$end)#
    }#
  }#
  if (is.infinite(min_start) || is.infinite(max_end)) {#
    return(NULL)#
  }#
  return(list(start = min_start, end = max_end))#
}#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL,#
                               align_items = FALSE) { # Added 'align_items' option#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create document#
  # FIX 1: Change DATE format to comply with XML Schema's 'dateTime' format (e.g., "+02:00")#
  date_string <- format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z")#
  date_string <- sub("([+-][0-9]{2})([0-9]{2})$", "\\1:\\2", date_string) # Reformat timezone#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = date_string, #
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file)) {#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Build link maps#
  parent_map <- list()#
  children_map <- list()#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Store level info #
  level_map <- list()#
  for (level in emu_data$levels) {#
    for (item in level$items) {#
      level_map[[as.character(item$id)]] <- level$name#
    }#
  }#
#
  # Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points from SEGMENT and EVENT levels#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  # Collect time points for ITEM tiers if align_items is TRUE#
  if (align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          time_range <- get_item_time_range(item_id, emu_data, children_map, time_slot_map, level_map)#
          if (!is.null(time_range)) {#
            all_time_points <- c(all_time_points, time_range$start, time_range$end)#
          }#
        }#
      }#
    }#
  }#
#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Store annotation IDs#
  annotation_map <- list()#
  # 1. Create all tiers with time-aligned annotations (SEGMENT, EVENT, and ITEM if align_items=TRUE)#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT") || (level$type == "ITEM" && align_items)) {#
      # Create tier#
      tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = "default-lt")#
      for (item in level$items) {#
        item_id <- as.character(item$id)#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        ann_id <- paste0("a", item_id)#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          # Use first label for SEGMENT/EVENT, or combined labels for ITEM#
          label_values <- sapply(item$labels, function(l) l$value)#
          annot_value <- paste(label_values, collapse = "; ")#
        }#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          start_ms <- point_ms#
          end_ms <- point_ms#
        } else if (level$type == "ITEM" && align_items) {#
          time_range <- get_item_time_range(item_id, emu_data, children_map, time_slot_map, level_map)#
          if (is.null(time_range)) next # Skip if no time-aligned children found#
          start_ms <- time_range$start#
          end_ms <- time_range$end#
        } else {#
          next # Should not happen based on condition#
        }#
        alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                 ANNOTATION_ID = ann_id,#
                                 TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                 TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        annotation_map[[item_id]] <- ann_id#
      }#
    }#
  }#
  # 2. Now create ITEM tiers with REF_ANNOTATIONs (only if align_items=FALSE)#
  if (!align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        # --- LINGUISTIC TYPE AND PARENT DETERMINATION FIX ---#
        parent_tier_name <- NULL#
        for (item in level$items) {#
          parent_id <- parent_map[[as.character(item$id)]]#
          if (!is.null(parent_id) && !is.null(level_map[[parent_id]])) {#
            parent_tier_name <- level_map[[parent_id]]#
            break#
          }#
        }#
        tier_attrs <- list(TIER_ID = level$name)#
        if (!is.null(parent_tier_name)) {#
          tier_attrs$PARENT_REF <- parent_tier_name#
          # Check if the parent tier is time-aligned (SEGMENT/EVENT)#
          parent_level_obj <- emu_data$levels[[which(sapply(emu_data$levels, function(l) l$name == parent_tier_name))]]#
          if (!is.null(parent_level_obj) && parent_level_obj$type %in% c("SEGMENT", "EVENT")) {#
              tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-subdivision"#
          } else {#
              tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
          }#
        } else {#
          # FIX 2: If no parent is found (like Utterance), set to 'default-lt' to avoid #
          # Symbolic_Association constraint error for a root tier.#
          tier_attrs$LINGUISTIC_TYPE_REF <- "default-lt"#
        }#
        tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
        # Add annotations#
        prev_annotation_id <- NULL#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          parent_id <- parent_map[[item_id]]#
          # Find a valid parent annotation ID#
          parent_ann_id <- NULL#
          if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
            parent_ann_id <- annotation_map[[parent_id]]#
          }#
          # FIX 3: Removed the faulty fallback that linked to annotation_map[[1]] #
          # which caused structural errors. Now, it only creates a REF_ANNOTATION if a correct link is found.#
          if (!is.null(parent_ann_id)) {#
            # Only create REF_ANNOTATION if the tier is symbolic (not default-lt)#
            if (tier_attrs$LINGUISTIC_TYPE_REF %in% c("symbolic-subdivision", "symbolic-association")) {#
              annotation <- xml_add_child(tier, "ANNOTATION")#
              # Get all label values#
              annot_value <- ""#
              if (!is.null(item$labels) && length(item$labels) > 0) {#
                label_values <- sapply(item$labels, function(l) l$value)#
                annot_value <- paste(label_values, collapse = "; ")#
              }#
              ann_id <- paste0("a", item_id)#
              ref_attrs <- list(#
                ANNOTATION_ID = ann_id,#
                ANNOTATION_REF = parent_ann_id#
              )#
              # Add previous annotation for chaining if using subdivision#
              if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
                ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
              }#
              ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
              xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
              annotation_map[[item_id]] <- ann_id#
              prev_annotation_id <- ann_id#
            }#
          }#
        }#
      }#
    }#
  }#
  # Add linguistic types (ensuring no redundant types are added)#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  # Add constraints#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf")
library(jsonlite)#
library(xml2)#
#
# Helper function to recursively find the time range for an ITEM annotation#
get_item_time_range <- function(item_id, emu_data, children_map, time_points_map, level_map) {#
  # Base case: if item_id is a segment or event (i.e., time-aligned)#
  if (level_map[[item_id]] %in% c("SEGMENT", "EVENT")) {#
    level <- emu_data$levels[[which(sapply(emu_data$levels, function(l) l$name == level_map[[item_id]]))]]#
    item <- level$items[[which(sapply(level$items, function(i) as.character(i$id) == item_id))]]#
    if (level$type == "SEGMENT") {#
      start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
      end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
    } else { # EVENT#
      point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
      start_ms <- point_ms#
      end_ms <- point_ms#
    }#
    return(list(start = start_ms, end = end_ms))#
  }#
  # Recursive case: find children's time ranges#
  children_ids <- children_map[[item_id]]#
  if (is.null(children_ids)) {#
    return(NULL) # No time-aligned children#
  }#
  min_start <- Inf#
  max_end <- -Inf#
  for (child_id in children_ids) {#
    range <- get_item_time_range(child_id, emu_data, children_map, time_points_map, level_map)#
    if (!is.null(range)) {#
      min_start <- min(min_start, range$start)#
      max_end <- max(max_end, range$end)#
    }#
  }#
  if (is.infinite(min_start) || is.infinite(max_end)) {#
    return(NULL)#
  }#
  return(list(start = min_start, end = max_end))#
}#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL,#
                               align_items = FALSE) { # New argument#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create document#
  # FIX 1: Change DATE format to comply with XML Schema's 'dateTime' format (e.g., "+02:00")#
  date_string <- format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z")#
  date_string <- sub("([+-][0-9]{2})([0-9]{2})$", "\\1:\\2", date_string) # Reformat timezone#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = date_string, #
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER (unchanged)#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file)) {#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Build link maps (unchanged)#
  parent_map <- list()#
  children_map <- list()#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Store level info (unchanged)#
  level_map <- list()#
  for (level in emu_data$levels) {#
    for (item in level$items) {#
      level_map[[as.character(item$id)]] <- level$name#
    }#
  }#
#
  # Create TIME_ORDER (unchanged)#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points (unchanged)#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  # Collect time points for ITEM tiers if align_items is TRUE (unchanged)#
  if (align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          time_range <- get_item_time_range(item_id, emu_data, children_map, time_slot_map, level_map)#
          if (!is.null(time_range)) {#
            all_time_points <- c(all_time_points, time_range$start, time_range$end)#
          }#
        }#
      }#
    }#
  }#
#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Store annotation IDs#
  annotation_map <- list()#
  # 1. Create all tiers with time-aligned annotations (SEGMENT, EVENT, and ITEM if align_items=TRUE)#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT") || (level$type == "ITEM" && align_items)) {#
      # Create tier#
      tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = "default-lt")#
      for (item in level$items) {#
        item_id <- as.character(item$id)#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        ann_id <- paste0("a", item_id)#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          label_values <- sapply(item$labels, function(l) l$value)#
          annot_value <- paste(label_values, collapse = "; ")#
        }#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          start_ms <- point_ms#
          end_ms <- point_ms#
        } else if (level$type == "ITEM" && align_items) {#
          time_range <- get_item_time_range(item_id, emu_data, children_map, time_slot_map, level_map)#
          if (is.null(time_range)) next#
          start_ms <- time_range$start#
          end_ms <- time_range$end#
        } else {#
          next #
        }#
        alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                 ANNOTATION_ID = ann_id,#
                                 TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                 TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        annotation_map[[item_id]] <- ann_id#
      }#
    }#
  }#
  # 2. Now create ITEM tiers with REF_ANNOTATIONs (only if align_items=FALSE)#
  if (!align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        # --- LINGUISTIC TYPE AND PARENT DETERMINATION FIX ---#
        parent_tier_name <- NULL#
        for (item in level$items) {#
          parent_id <- parent_map[[as.character(item$id)]]#
          if (!is.null(parent_id) && !is.null(level_map[[parent_id]])) {#
            parent_tier_name <- level_map[[parent_id]]#
            break#
          }#
        }#
        tier_attrs <- list(TIER_ID = level$name)#
        if (!is.null(parent_tier_name)) {#
          tier_attrs$PARENT_REF <- parent_tier_name#
          # Check if the parent tier is time-aligned (SEGMENT/EVENT)#
          parent_level_obj <- emu_data$levels[[which(sapply(emu_data$levels, function(l) l$name == parent_tier_name))]]#
          if (!is.null(parent_level_obj) && parent_level_obj$type %in% c("SEGMENT", "EVENT")) {#
              tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-subdivision"#
          } else {#
              tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
          }#
        } else {#
          # FIX 2 (REVERTED): To make the root ITEM annotations appear, we must force the symbolic type.#
          # This re-introduces the "Symbolic_Association" constraint error for Utterance, #
          # but allows its annotations to be created.#
          tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
          # NOTE: PARENT_REF is still absent, which causes the ELAN validator error for root tiers.#
        }#
        tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
        # Add annotations#
        prev_annotation_id <- NULL#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          parent_id <- parent_map[[item_id]]#
          # Find a valid parent annotation ID#
          parent_ann_id <- NULL#
          if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
            parent_ann_id <- annotation_map[[parent_id]]#
          }#
          # This block correctly creates annotations for symbolically linked tiers (e.g., Word, Syllable, etc.)#
          if (tier_attrs$LINGUISTIC_TYPE_REF %in% c("symbolic-subdivision", "symbolic-association") && !is.null(parent_ann_id)) {#
            annotation <- xml_add_child(tier, "ANNOTATION")#
            # Get all label values#
            annot_value <- ""#
            if (!is.null(item$labels) && length(item$labels) > 0) {#
              label_values <- sapply(item$labels, function(l) l$value)#
              annot_value <- paste(label_values, collapse = "; ")#
            }#
            ann_id <- paste0("a", item_id)#
            ref_attrs <- list(#
              ANNOTATION_ID = ann_id,#
              ANNOTATION_REF = parent_ann_id#
            )#
            # Add previous annotation for chaining if using subdivision#
            if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
              ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
            }#
            ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
            xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
            annotation_map[[item_id]] <- ann_id#
            prev_annotation_id <- ann_id#
          } #
          # RE-INTRODUCING FUNCTIONALITY FOR ROOT SYMBOLIC ITEMS (like Utterance)#
          # These items have NO parent_ann_id, but need to be written to the file#
          # We must check if the current tier is a root symbolic tier (no parent_tier_name)#
          else if (is.null(parent_tier_name) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-association") {#
            # Since Utterance has no parent in the JSON, we need to artificially link it to #
            # the first time-aligned annotation ID in the entire file. This is the logic #
            # that made the file 'functional' but produced the validator error.#
            if (length(annotation_map) > 0) {#
              # Find the very first annotation ID created (from a SEGMENT or EVENT tier)#
              first_ann_id <- annotation_map[[1]] #
              annotation <- xml_add_child(tier, "ANNOTATION")#
              annot_value <- ""#
              if (!is.null(item$labels) && length(item$labels) > 0) {#
                label_values <- sapply(item$labels, function(l) l$value)#
                annot_value <- paste(label_values, collapse = "; ")#
              }#
              ann_id <- paste0("a", item_id)#
              ref_attrs <- list(#
                ANNOTATION_ID = ann_id,#
                ANNOTATION_REF = first_ann_id # Fails validation but makes it display#
              )#
              ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
              xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
              annotation_map[[item_id]] <- ann_id#
            }#
          }#
        }#
      }#
    }#
  }#
  # Add linguistic types and constraints (unchanged)#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf")
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf",align_items=TRUE)
library(jsonlite)#
library(xml2)#
#
# Helper function to recursively find the time range for an ITEM annotation#
get_item_time_range <- function(item_id, emu_data, children_map, time_points_map, level_map) {#
  # Base case: if item_id is a segment or event (i.e., time-aligned)#
  if (level_map[[item_id]] %in% c("SEGMENT", "EVENT")) {#
    level <- emu_data$levels[[which(sapply(emu_data$levels, function(l) l$name == level_map[[item_id]]))]]#
    item <- level$items[[which(sapply(level$items, function(i) as.character(i$id) == item_id))]]#
    if (level$type == "SEGMENT") {#
      start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
      end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
    } else { # EVENT#
      point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
      start_ms <- point_ms#
      end_ms <- point_ms#
    }#
    return(list(start = start_ms, end = end_ms))#
  }#
  # Recursive case: find children's time ranges#
  children_ids <- children_map[[item_id]]#
  if (is.null(children_ids)) {#
    return(NULL) # No time-aligned children#
  }#
  min_start <- Inf#
  max_end <- -Inf#
  for (child_id in children_ids) {#
    range <- get_item_time_range(child_id, emu_data, children_map, time_points_map, level_map)#
    if (!is.null(range)) {#
      min_start <- min(min_start, range$start)#
      max_end <- max(max_end, range$end)#
    }#
  }#
  if (is.infinite(min_start) || is.infinite(max_end)) {#
    return(NULL)#
  }#
  return(list(start = min_start, end = max_end))#
}#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL,#
                               align_items = FALSE) { # New argument#
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create document#
  # FIX: Change DATE format to comply with XML Schema's 'dateTime' format (e.g., "+02:00")#
  date_string <- format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z")#
  date_string <- sub("([+-][0-9]{2})([0-9]{2})$", "\\1:\\2", date_string) # Reformat timezone#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = date_string, #
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file)) {#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Build link maps#
  parent_map <- list()#
  children_map <- list()#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Store level info #
  level_map <- list()#
  for (level in emu_data$levels) {#
    for (item in level$items) {#
      level_map[[as.character(item$id)]] <- level$name#
    }#
  }#
#
  # Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points (SEGMENT/EVENT + ITEM if align_items=TRUE)#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  if (align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          time_range <- get_item_time_range(item_id, emu_data, children_map, time_slot_map, level_map)#
          if (!is.null(time_range)) {#
            all_time_points <- c(all_time_points, time_range$start, time_range$end)#
          }#
        }#
      }#
    }#
  }#
#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Store annotation IDs#
  annotation_map <- list()#
  # 1. Create all tiers with time-aligned annotations (SEGMENT, EVENT, and ITEM if align_items=TRUE)#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT") || (level$type == "ITEM" && align_items)) {#
      # Create tier#
      tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = "default-lt")#
      for (item in level$items) {#
        item_id <- as.character(item$id)#
        # --- FIX: Calculate times first, skip if invalid for ITEMs, then add <ANNOTATION> tag. ---#
        start_ms <- NULL#
        end_ms <- NULL#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          start_ms <- point_ms#
          end_ms <- point_ms#
        } else if (level$type == "ITEM" && align_items) {#
          time_range <- get_item_time_range(item_id, emu_data, children_map, time_slot_map, level_map)#
          if (is.null(time_range)) next # Skip the annotation entirely if no time-aligned children are found#
          start_ms <- time_range$start#
          end_ms <- time_range$end#
        } else {#
          next # Should not happen based on condition#
        }#
#
        # --- ANNOTATION CREATION (Moved here) ---#
        annotation <- xml_add_child(tier, "ANNOTATION")#
        ann_id <- paste0("a", item_id)#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          label_values <- sapply(item$labels, function(l) l$value)#
          annot_value <- paste(label_values, collapse = "; ")#
        }#
        alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                 ANNOTATION_ID = ann_id,#
                                 TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                 TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        annotation_map[[item_id]] <- ann_id#
      }#
    }#
  }#
  # 2. Now create ITEM tiers with REF_ANNOTATIONs (only if align_items=FALSE)#
  if (!align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        # --- LINGUISTIC TYPE AND PARENT DETERMINATION ---#
        parent_tier_name <- NULL#
        for (item in level$items) {#
          parent_id <- parent_map[[as.character(item$id)]]#
          if (!is.null(parent_id) && !is.null(level_map[[parent_id]])) {#
            parent_tier_name <- level_map[[parent_id]]#
            break#
          }#
        }#
        tier_attrs <- list(TIER_ID = level$name)#
        if (!is.null(parent_tier_name)) {#
          tier_attrs$PARENT_REF <- parent_tier_name#
          # Check if the parent tier is time-aligned (SEGMENT/EVENT)#
          parent_level_obj <- emu_data$levels[[which(sapply(emu_data$levels, function(l) l$name == parent_tier_name))]]#
          if (!is.null(parent_level_obj) && parent_level_obj$type %in% c("SEGMENT", "EVENT")) {#
              tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-subdivision"#
          } else {#
              tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
          }#
        } else {#
          # REVERTED TO FUNCTIONAL LOGIC (for Utterance to display)#
          tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
        }#
        tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
        # Add annotations#
        prev_annotation_id <- NULL#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          parent_id <- parent_map[[item_id]]#
          # Find a valid parent annotation ID#
          parent_ann_id <- NULL#
          if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
            parent_ann_id <- annotation_map[[parent_id]]#
          }#
          # Symbolic links (Word->Syllable, etc.)#
          if (tier_attrs$LINGUISTIC_TYPE_REF %in% c("symbolic-subdivision", "symbolic-association") && !is.null(parent_ann_id)) {#
            annotation <- xml_add_child(tier, "ANNOTATION")#
            # Get all label values#
            annot_value <- ""#
            if (!is.null(item$labels) && length(item$labels) > 0) {#
              label_values <- sapply(item$labels, function(l) l$value)#
              annot_value <- paste(label_values, collapse = "; ")#
            }#
            ann_id <- paste0("a", item_id)#
            ref_attrs <- list(#
              ANNOTATION_ID = ann_id,#
              ANNOTATION_REF = parent_ann_id#
            )#
            # Add previous annotation for chaining if using subdivision#
            if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
              ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
            }#
            ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
            xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
            annotation_map[[item_id]] <- ann_id#
            prev_annotation_id <- ann_id#
          } #
          # Root symbolic items (Utterance) - Functional Revert#
          else if (is.null(parent_tier_name) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-association") {#
            # Find the very first annotation ID created (from a SEGMENT or EVENT tier)#
            # This is the "functional" (but validation-failing) way to link a root symbolic tier.#
            if (length(annotation_map) > 0) {#
              first_ann_id <- annotation_map[[1]] #
              annotation <- xml_add_child(tier, "ANNOTATION")#
              annot_value <- ""#
              if (!is.null(item$labels) && length(item$labels) > 0) {#
                label_values <- sapply(item$labels, function(l) l$value)#
                annot_value <- paste(label_values, collapse = "; ")#
              }#
              ann_id <- paste0("a", item_id)#
              ref_attrs <- list(#
                ANNOTATION_ID = ann_id,#
                ANNOTATION_REF = first_ann_id #
              )#
              ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
              xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
              annotation_map[[item_id]] <- ann_id#
            }#
          }#
        }#
      }#
    }#
  }#
  # Add linguistic types and constraints (unchanged)#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf",align_items=TRUE)
library(jsonlite)#
library(xml2)#
#
# Helper function to recursively find the time range for an ITEM annotation#
# NEW ARGUMENT: level_type_map is included to resolve level type by name.#
get_item_time_range <- function(item_id, emu_data, children_map, time_points_map, level_map, level_type_map) {#
  level_name <- level_map[[item_id]]#
  level_type <- level_type_map[[level_name]] # <--- CORRECTLY RESOLVE LEVEL TYPE#
  # Base case: if item_id belongs to a segment or event level (i.e., time-aligned)#
  if (level_type %in% c("SEGMENT", "EVENT")) { #
    level_list_index <- which(sapply(emu_data$levels, function(l) l$name == level_name))#
    level <- emu_data$levels[[level_list_index]]#
    item <- level$items[[which(sapply(level$items, function(i) as.character(i$id) == item_id))]]#
    if (level$type == "SEGMENT") {#
      start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
      end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
    } else { # EVENT#
      point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
      start_ms <- point_ms#
      end_ms <- point_ms#
    }#
    return(list(start = start_ms, end = end_ms))#
  }#
  # Recursive case: find children's time ranges#
  children_ids <- children_map[[item_id]]#
  if (is.null(children_ids)) {#
    return(NULL) #
  }#
  min_start <- Inf#
  max_end <- -Inf#
  for (child_id in children_ids) {#
    # Recursively call the helper, passing the necessary maps#
    range <- get_item_time_range(child_id, emu_data, children_map, time_points_map, level_map, level_type_map)#
    if (!is.null(range)) {#
      min_start <- min(min_start, range$start)#
      max_end <- max(max_end, range$end)#
    }#
  }#
  if (is.infinite(min_start) || is.infinite(max_end)) {#
    return(NULL)#
  }#
  return(list(start = min_start, end = max_end))#
}#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL,#
                               align_items = FALSE) { #
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
  if (is.null(media_file) && !is.null(emu_data$annotates)) {#
    media_file <- emu_data$annotates#
  }#
  # Create document#
  date_string <- format(Sys.time(), "%Y-%m-%dT%H:%M:%S%z")#
  date_string <- sub("([+-][0-9]{2})([0-9]{2})$", "\\1:\\2", date_string) # Fix timezone format#
  doc <- xml_new_root("ANNOTATION_DOCUMENT",#
                      AUTHOR = author,#
                      DATE = date_string, #
                      FORMAT = "3.0",#
                      VERSION = "3.0",#
                      "xmlns:xsi" = "http://www.w3.org/2001/XMLSchema-instance",#
                      "xsi:noNamespaceSchemaLocation" = "http://www.mpi.nl/tools/elan/EAFv3.0.xsd")#
  # Add HEADER#
  header <- xml_add_child(doc, "HEADER", TIME_UNITS = "milliseconds")#
  if (!is.null(media_file)) {#
    media_url <- paste0("file://", normalizePath(media_file, mustWork = FALSE))#
    xml_add_child(header, "MEDIA_DESCRIPTOR",#
                  MEDIA_URL = media_url,#
                  MIME_TYPE = "audio/x-wav",#
                  RELATIVE_MEDIA_URL = paste0("./", basename(media_file)))#
  }#
  # Build link maps#
  parent_map <- list()#
  children_map <- list()#
  if (!is.null(emu_data$links)) {#
    for (link in emu_data$links) {#
      from_id <- as.character(link$fromID)#
      to_id <- as.character(link$toID)#
      parent_map[[to_id]] <- from_id#
      if (is.null(children_map[[from_id]])) {#
        children_map[[from_id]] <- list()#
      }#
      children_map[[from_id]] <- append(children_map[[from_id]], to_id)#
    }#
  }#
  # Store level info and map level name to type#
  level_map <- list() # ID -> Level Name#
  level_type_map <- list() # Level Name -> Level Type#
  for (level in emu_data$levels) {#
    level_type_map[[level$name]] <- level$type#
    for (item in level$items) {#
      level_map[[as.character(item$id)]] <- level$name #
    }#
  }#
#
  # Create TIME_ORDER#
  time_order <- xml_add_child(doc, "TIME_ORDER")#
  time_slot_map <- list()#
  time_slot_counter <- 1#
  all_time_points <- c()#
  # Collect time points (SEGMENT/EVENT + ITEM if align_items=TRUE)#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT")) {#
      for (item in level$items) {#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, start_ms, end_ms)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          all_time_points <- c(all_time_points, point_ms)#
        }#
      }#
    }#
  }#
  if (align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          # Pass the new level_type_map#
          time_range <- get_item_time_range(item_id, emu_data, children_map, time_slot_map, level_map, level_type_map)#
          if (!is.null(time_range)) {#
            all_time_points <- c(all_time_points, time_range$start, time_range$end)#
          }#
        }#
      }#
    }#
  }#
#
  unique_times <- sort(unique(all_time_points))#
  for (time_val in unique_times) {#
    ts_id <- paste0("ts", time_slot_counter)#
    xml_add_child(time_order, "TIME_SLOT",#
                  TIME_SLOT_ID = ts_id,#
                  TIME_VALUE = as.character(time_val))#
    time_slot_map[[as.character(time_val)]] <- ts_id#
    time_slot_counter <- time_slot_counter + 1#
  }#
  # Store annotation IDs#
  annotation_map <- list()#
  # 1. Create all tiers with time-aligned annotations (SEGMENT, EVENT, and ITEM if align_items=TRUE)#
  for (level in emu_data$levels) {#
    if (level$type %in% c("SEGMENT", "EVENT") || (level$type == "ITEM" && align_items)) {#
      # Create tier#
      tier <- xml_add_child(doc, "TIER",#
                          TIER_ID = level$name,#
                          LINGUISTIC_TYPE_REF = "default-lt")#
      for (item in level$items) {#
        item_id <- as.character(item$id)#
        start_ms <- NULL#
        end_ms <- NULL#
        if (level$type == "SEGMENT") {#
          start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
          end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
        } else if (level$type == "EVENT") {#
          point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
          start_ms <- point_ms#
          end_ms <- point_ms#
        } else if (level$type == "ITEM" && align_items) {#
          # Pass the new level_type_map#
          time_range <- get_item_time_range(item_id, emu_data, children_map, time_slot_map, level_map, level_type_map)#
          if (is.null(time_range)) next # Skip the annotation entirely if no time-aligned children are found#
          start_ms <- time_range$start#
          end_ms <- time_range$end#
        } else {#
          next #
        }#
#
        # ANNOTATION CREATION #
        annotation <- xml_add_child(tier, "ANNOTATION")#
        ann_id <- paste0("a", item_id)#
        annot_value <- ""#
        if (!is.null(item$labels) && length(item$labels) > 0) {#
          label_values <- sapply(item$labels, function(l) l$value)#
          annot_value <- paste(label_values, collapse = "; ")#
        }#
        alignable <- xml_add_child(annotation, "ALIGNABLE_ANNOTATION",#
                                 ANNOTATION_ID = ann_id,#
                                 TIME_SLOT_REF1 = time_slot_map[[as.character(start_ms)]],#
                                 TIME_SLOT_REF2 = time_slot_map[[as.character(end_ms)]])#
        xml_add_child(alignable, "ANNOTATION_VALUE", annot_value)#
        annotation_map[[item_id]] <- ann_id#
      }#
    }#
  }#
  # 2. Now create ITEM tiers with REF_ANNOTATIONs (only if align_items=FALSE)#
  if (!align_items) {#
    for (level in emu_data$levels) {#
      if (level$type == "ITEM") {#
        parent_tier_name <- NULL#
        for (item in level$items) {#
          parent_id <- parent_map[[as.character(item$id)]]#
          if (!is.null(parent_id) && !is.null(level_map[[parent_id]])) {#
            parent_tier_name <- level_map[[parent_id]]#
            break#
          }#
        }#
        tier_attrs <- list(TIER_ID = level$name)#
        if (!is.null(parent_tier_name)) {#
          tier_attrs$PARENT_REF <- parent_tier_name#
          parent_level_obj <- emu_data$levels[[which(sapply(emu_data$levels, function(l) l$name == parent_tier_name))]]#
          if (!is.null(parent_level_obj) && parent_level_obj$type %in% c("SEGMENT", "EVENT")) {#
              tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-subdivision"#
          } else {#
              tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
          }#
        } else {#
          # Functional logic for root symbolic tiers (like Utterance)#
          tier_attrs$LINGUISTIC_TYPE_REF <- "symbolic-association"#
        }#
        tier <- do.call(xml_add_child, c(list(doc, "TIER"), tier_attrs))#
        # Add annotations#
        prev_annotation_id <- NULL#
        for (item in level$items) {#
          item_id <- as.character(item$id)#
          parent_id <- parent_map[[item_id]]#
          parent_ann_id <- NULL#
          if (!is.null(parent_id) && !is.null(annotation_map[[parent_id]])) {#
            parent_ann_id <- annotation_map[[parent_id]]#
          }#
          # Symbolic links #
          if (tier_attrs$LINGUISTIC_TYPE_REF %in% c("symbolic-subdivision", "symbolic-association") && !is.null(parent_ann_id)) {#
            annotation <- xml_add_child(tier, "ANNOTATION")#
            annot_value <- ""#
            if (!is.null(item$labels) && length(item$labels) > 0) {#
              label_values <- sapply(item$labels, function(l) l$value)#
              annot_value <- paste(label_values, collapse = "; ")#
            }#
            ann_id <- paste0("a", item_id)#
            ref_attrs <- list(#
              ANNOTATION_ID = ann_id,#
              ANNOTATION_REF = parent_ann_id#
            )#
            if (!is.null(prev_annotation_id) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-subdivision") {#
              ref_attrs$PREVIOUS_ANNOTATION <- prev_annotation_id#
            }#
            ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
            xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
            annotation_map[[item_id]] <- ann_id#
            prev_annotation_id <- ann_id#
          } #
          # Root symbolic items (Utterance) - Functional Revert logic#
          else if (is.null(parent_tier_name) && tier_attrs$LINGUISTIC_TYPE_REF == "symbolic-association") {#
            if (length(annotation_map) > 0) {#
              first_ann_id <- annotation_map[[1]] #
              annotation <- xml_add_child(tier, "ANNOTATION")#
              annot_value <- ""#
              if (!is.null(item$labels) && length(item$labels) > 0) {#
                label_values <- sapply(item$labels, function(l) l$value)#
                annot_value <- paste(label_values, collapse = "; ")#
              }#
              ann_id <- paste0("a", item_id)#
              ref_attrs <- list(#
                ANNOTATION_ID = ann_id,#
                ANNOTATION_REF = first_ann_id #
              )#
              ref_annot <- do.call(xml_add_child, c(list(annotation, "REF_ANNOTATION"), ref_attrs))#
              xml_add_child(ref_annot, "ANNOTATION_VALUE", annot_value)#
              annotation_map[[item_id]] <- ann_id#
            }#
          }#
        }#
      }#
    }#
  }#
  # Add linguistic types and constraints #
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "default-lt",#
                TIME_ALIGNABLE = "true",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-subdivision",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Subdivision",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "LINGUISTIC_TYPE",#
                LINGUISTIC_TYPE_ID = "symbolic-association",#
                TIME_ALIGNABLE = "false",#
                CONSTRAINTS = "Symbolic_Association",#
                GRAPHIC_REFERENCES = "false")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Time_Subdivision",#
                DESCRIPTION = "Time subdivision of parent annotation's time interval, no time gaps allowed within this interval")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Subdivision",#
                DESCRIPTION = "Symbolic subdivision of a parent annotation. Annotations refering to the same parent are ordered")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Symbolic_Association",#
                DESCRIPTION = "1-1 association with a parent annotation")#
  xml_add_child(doc, "CONSTRAINT",#
                STEREOTYPE = "Included_In",#
                DESCRIPTION = "Time alignable annotations within the parent annotation's time interval, gaps are allowed")#
  # Write file#
  write_xml(doc, eaf_file)#
  message(paste("Successfully converted", json_file, "to", eaf_file))#
  return(invisible(eaf_file))#
}
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf",align_items=TRUE)
convert_emu_to_eaf("Downloads/msajc012_annot.json", "msajc012.eaf")
