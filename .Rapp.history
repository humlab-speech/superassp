# ==============================================================================#
# MAIN FUNCTION: BUILD EMU DATABASE CACHE#
# ==============================================================================#
#
#' Build emuDB cache and return S7 corpus object#
#' @param database_dir Path to the emuDB directory#
#' @param parallel Use parallel processing (default: TRUE)#
#' @param workers Number of parallel workers (default: availableCores() - 1)#
#' @param batch_size Number of bundles to process in each batch for DB insertion#
#' @param verbose Show progress information#
#' @return S7 corpus object#
build_emuDB_cache <- function(database_dir, #
                              parallel = TRUE,#
                              workers = future::availableCores() - 1,#
                              batch_size = 50,#
                              verbose = TRUE) {#
