library(jsonlite)#
library(xml2)#
library(av)#
#
# Helper function to recursively find the time range for an ITEM annotation#
get_item_time_range <- function(item_id, emu_data, children_map, time_points_map, level_map, level_type_map) {#
  level_name <- level_map[[item_id]]#
  level_type <- level_type_map[[level_name]]#
  # Base case: if item_id belongs to a segment or event level (i.e., time-aligned)#
  if (level_type %in% c("SEGMENT", "EVENT")) { #
    level_list_index <- which(sapply(emu_data$levels, function(l) l$name == level_name))#
    level <- emu_data$levels[[level_list_index]]#
    item <- level$items[[which(sapply(level$items, function(i) as.character(i$id) == item_id))]]#
    if (level$type == "SEGMENT") {#
      start_ms <- round((item$sampleStart / emu_data$sampleRate) * 1000)#
      end_ms <- round(((item$sampleStart + item$sampleDur) / emu_data$sampleRate) * 1000)#
    } else { # EVENT#
      point_ms <- round((item$samplePoint / emu_data$sampleRate) * 1000)#
      start_ms <- point_ms#
      end_ms <- point_ms#
    }#
    return(list(start = start_ms, end = end_ms))#
  }#
  # Recursive case: find children's time ranges#
  children_ids <- children_map[[item_id]]#
  if (is.null(children_ids)) {#
    return(NULL) #
  }#
  min_start <- Inf#
  max_end <- -Inf#
  for (child_id in children_ids) {#
    range <- get_item_time_range(child_id, emu_data, children_map, time_points_map, level_map, level_type_map)#
    if (!is.null(range)) {#
      min_start <- min(min_start, range$start)#
      max_end <- max(max_end, range$end)#
    }#
  }#
  if (is.infinite(min_start) || is.infinite(max_end)) {#
    return(NULL)#
  }#
  return(list(start = min_start, end = max_end))#
}#
convert_emu_to_eaf <- function(json_file, eaf_file = NULL, #
                               author = "EMU-to-ELAN Converter",#
                               media_file = NULL,#
                               align_items = FALSE) { #
  if (is.null(eaf_file)) {#
    eaf_file <- sub("_annot\\.json$", ".eaf", json_file)#
  }#
  # Read JSON#
  emu_data <- fromJSON(json_file, simplifyVector = FALSE)#
