# Example usage and testing functions#
#
#' Test the new query engine with example queries#
test_newquery <- function(emuDB) {#
  test_queries <- c(#
    # Simple label queries#
    "Phonetic == 'n'",#
    "Word != 'the'",#
    "Phoneme =~ '^[aeiou]'",#
    # Sequence queries#
    "[Phonetic == 't' -> Phonetic == 'u:']",#
    # Dominance queries  #
    "[Word == 'beautiful' ^ Phonetic == 'bj']",#
    # Function queries#
    "Start(Phonetic, Word) == 1",#
    "Num(Phonetic, Word) > 3",#
    # Complex combinations#
    "[Word == 'water' ^ [Phonetic == 'w' -> Phonetic == 'O:']]",#
    "#[Phonetic == 'n' & Word == 'and']"#
  )#
  cat("Testing", length(test_queries), "example queries...\n")#
  results <- list()#
  for (i in seq_along(test_queries)) {#
    cat("Testing query", i, ":", test_queries[i], "\n")#
    tryCatch({#
      start_time <- Sys.time()#
      result <- newquery(emuDB, test_queries[i])#
      end_time <- Sys.time()#
      results[[i]] <- list(#
        query = test_queries[i],#
        success = TRUE,#
        rows = nrow(result),#
        execution_time = as.numeric(end_time - start_time),#
        result = head(result, 3)  # Store first 3 rows for inspection#
      )#
      cat("  Success:", nrow(result), "rows in", #
          round(as.numeric(end_time - start_time), 3), "seconds\n")#
    }, error = function(e) {#
      results[[i]] <- list(#
        query = test_queries[i],#
        success = FALSE,#
        error = e$message#
      )#
      cat("  Error:", e$message, "\n")#
    })#
  }#
  return(results)#
}
