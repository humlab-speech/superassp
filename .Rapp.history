  if (verbose) {#
    cli::cli_h1("Building emuDB cache for {.field {db_name}}")#
  }#
  # Initialize SQLite connection#
  if (file.exists(cache_path)) {#
    if (verbose) cli::cli_alert_info("Removing existing cache file")#
    unlink(cache_path)#
  }#
  con <- DBI::dbConnect(RSQLite::SQLite(), cache_path)#
  on.exit(DBI::dbDisconnect(con), add = TRUE)#
  # Initialize database schema#
  initialize_database_schema(con, db_config$UUID, db_name)#
