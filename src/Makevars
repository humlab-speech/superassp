
PKG_CPPFLAGS = -I assp -DWRASSP -I SPTK/include -I SPTK/third_party -I SPTK/third_party/REAPER -I SPTK/third_party/WORLD -I opensmile/src/include -I opensmile/progsrc/include -I opensmile/build_r/src -I tandem/tandem_64 -I ../inst/onnxruntime/include -DRCPPXSIMD_AVAILABLE

# On macOS, Xcode 16+ ships the real libc++ headers inside the SDK rather than
# at the legacy CommandLineTools path.  The stale stub directory at
#   /Library/Developer/CommandLineTools/usr/include/c++/v1/
# contains only three old files and shadows the full SDK headers, making
# <cmath> and other standard headers invisible.  We prepend the SDK's own
# c++/v1 directory so it is found first.
ifeq ($(shell uname -s),Darwin)
MACOS_SDK := $(shell xcrun --show-sdk-path 2>/dev/null)
PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS) -std=c++11 -I$(MACOS_SDK)/usr/include/c++/v1
else
PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS) -std=c++11
endif
PKG_LIBS = $(shell pwd)/opensmile/build_r/libopensmile.a -ldl $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)

